    "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Star Defender - 3D Rail Shooter</title>\n<style>\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n  touch-action: none;\n}\n\nbody {\n  overflow: hidden;\n  font-family: 'Arial', sans-serif;\n  background: #000;\n}\n\n#gameCanvas {\n  display: block;\n  width: 100%;\n  height: 100%;\n  position: absolute;\n  top: 0;\n  left: 0;\n}\n\n#ui {\n  position: absolute;\n  top: 20px;\n  left: 20px;\n  color: #0f0;\n  font-size: 20px;\n  font-weight: bold;\n  text-shadow: 2px 2px 4px #000;\n  z-index: 10;\n  pointer-events: none;\n}\n\n#crosshair {\n  position: absolute;\n  width: 40px;\n  height: 40px;\n  border: 3px solid #0f0;\n  border-radius: 50%;\n  pointer-events: none;\n  z-index: 5;\n  box-shadow: 0 0 10px #0f0;\n}\n\n#crosshair::before,\n#crosshair::after {\n  content: '';\n  position: absolute;\n  background: #0f0;\n  box-shadow: 0 0 5px #0f0;\n}\n\n#crosshair::before {\n  width: 20px;\n  height: 2px;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n}\n\n#crosshair::after {\n  width: 2px;\n  height: 20px;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n}\n\n#gameOver {\n  display: none;\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  background: rgba(0, 0, 0, 0.9);\n  padding: 40px;\n  border: 3px solid #0f0;\n  border-radius: 10px;\n  text-align: center;\n  z-index: 100;\n  box-shadow: 0 0 30px #0f0;\n}\n\n#gameOver h1 {\n  color: #0f0;\n  font-size: 48px;\n  margin-bottom: 20px;\n  text-shadow: 0 0 10px #0f0;\n}\n\n#gameOver p {\n  color: #fff;\n  font-size: 24px;\n  margin: 10px 0;\n}\n\n#restartBtn {\n  margin-top: 30px;\n  padding: 15px 40px;\n  font-size: 24px;\n  font-weight: bold;\n  color: #000;\n  background: #0f0;\n  border: none;\n  border-radius: 5px;\n  cursor: pointer;\n  box-shadow: 0 0 20px #0f0;\n  transition: all 0.3s;\n}\n\n#restartBtn:hover {\n  background: #0f0;\n  box-shadow: 0 0 30px #0f0;\n  transform: scale(1.1);\n}\n\n/* Mobile Controls */\n#mobileControls {\n  display: none;\n  position: absolute;\n  bottom: 0;\n  left: 0;\n  width: 100%;\n  height: 40%;\n  z-index: 50;\n  grid-template-rows: 1fr 1fr;\n  grid-template-columns: 1fr 1fr 1fr;\n  gap: 10px;\n  padding: 20px;\n}\n\n@media (max-width: 768px) {\n  #mobileControls {\n    display: grid;\n  }\n}\n\n.control-area {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  position: relative;\n}\n\n/* D-Pad (Section 4: bottom-left) */\n#dpad {\n  grid-row: 2;\n  grid-column: 1;\n  position: relative;\n  width: 150px;\n  height: 150px;\n}\n\n.dpad-btn {\n  position: absolute;\n  width: 45px;\n  height: 45px;\n  background: rgba(0, 255, 0, 0.3);\n  border: 2px solid #0f0;\n  border-radius: 5px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: #0f0;\n  font-size: 24px;\n  font-weight: bold;\n  user-select: none;\n  box-shadow: 0 0 10px rgba(0, 255, 0, 0.5);\n}\n\n.dpad-btn.active {\n  background: rgba(0, 255, 0, 0.6);\n  box-shadow: 0 0 20px #0f0;\n}\n\n#btnUp { top: 0; left: 52px; }\n#btnDown { bottom: 0; left: 52px; }\n#btnLeft { top: 52px; left: 0; }\n#btnRight { top: 52px; right: 0; }\n\n/* Action Buttons (Section 6: bottom-right) */\n#actionBtns {\n  grid-row: 2;\n  grid-column: 3;\n  position: relative;\n  width: 180px;\n  height: 180px;\n}\n\n.action-btn {\n  position: absolute;\n  width: 60px;\n  height: 60px;\n  background: rgba(0, 255, 0, 0.3);\n  border: 3px solid #0f0;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: #0f0;\n  font-size: 20px;\n  font-weight: bold;\n  user-select: none;\n  box-shadow: 0 0 10px rgba(0, 255, 0, 0.5);\n}\n\n.action-btn.active {\n  background: rgba(0, 255, 0, 0.6);\n  box-shadow: 0 0 20px #0f0;\n}\n\n#btnA { bottom: 0; left: 0; }\n#btnB { bottom: 60px; left: 60px; }\n#btnC { bottom: 120px; left: 120px; }\n\n</style>\n</head>\n<body>\n\n<canvas id=\"gameCanvas\"></canvas>\n\n<div id=\"ui\">\n  <div>HEALTH: <span id=\"health\">100</span></div>\n  <div>SCORE: <span id=\"score\">0</span></div>\n  <div>BOMBS: <span id=\"bombs\">3</span></div>\n</div>\n\n<div id=\"crosshair\"></div>\n\n<div id=\"gameOver\">\n  <h1>MISSION COMPLETE</h1>\n  <p>FINAL SCORE: <span id=\"finalScore\">0</span></p>\n  <p id=\"statusText\">VICTORY!</p>\n  <button id=\"restartBtn\">RESTART MISSION</button>\n</div>\n\n<!-- Mobile Controls -->\n<div id=\"mobileControls\">\n  <!-- D-Pad Section 4 (bottom-left) -->\n  <div class=\"control-area\" id=\"dpad\" style=\"grid-row: 2; grid-column: 1;\">\n    <div class=\"dpad-btn\" id=\"btnUp\">\u25b2</div>\n    <div class=\"dpad-btn\" id=\"btnDown\">\u25bc</div>\n    <div class=\"dpad-btn\" id=\"btnLeft\">\u25c4</div>\n    <div class=\"dpad-btn\" id=\"btnRight\">\u25ba</div>\n  </div>\n  \n  <!-- Action Buttons Section 6 (bottom-right) -->\n  <div class=\"control-area\" id=\"actionBtns\" style=\"grid-row: 2; grid-column: 3;\">\n    <div class=\"action-btn\" id=\"btnA\">A</div>\n    <div class=\"action-btn\" id=\"btnB\">B</div>\n    <div class=\"action-btn\" id=\"btnC\">C</div>\n  </div>\n</div>\n\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js\"></script>\n\n<script>\n// ==================== GAME STATE ====================\nconst gameState = {\n  isGameOver: false,\n  score: 0,\n  health: 100,\n  bombs: 3,\n  zPosition: 0,\n  forwardSpeed: 0.5,\n  isRolling: false,\n  rollDirection: 0,\n  rollCooldown: 0,\n  lastTapTime: { left: 0, right: 0 },\n  invincible: false,\n  inBossFight: false,\n  bossDefeated: false\n};\n\n// Input state\nconst keys = {};\nconst mobileInput = {\n  up: false,\n  down: false,\n  left: false,\n  right: false,\n  shoot: false,\n  bomb: false,\n  roll: false\n};\n\n// ==================== SCENE SETUP ====================\nconst scene = new THREE.Scene();\nscene.fog = new THREE.Fog(0x000020, 50, 200);\n\nconst camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);\ncamera.position.z = 5;\n\nconst renderer = new THREE.WebGLRenderer({ canvas: document.getElementById('gameCanvas'), antialias: true });\nrenderer.setSize(window.innerWidth, window.innerHeight);\nrenderer.setClearColor(0x000020);\n\n// Lighting\nconst ambientLight = new THREE.AmbientLight(0x404040, 2);\nscene.add(ambientLight);\n\nconst directionalLight = new THREE.DirectionalLight(0xffffff, 1);\ndirectionalLight.position.set(5, 10, 5);\nscene.add(directionalLight);\n\n// ==================== PLAYER SHIP ====================\nconst playerGroup = new THREE.Group();\n\n// Ship body (Arwing-style)\nconst shipGeometry = new THREE.Group();\n\n// Main fuselage\nconst fuselageGeom = new THREE.ConeGeometry(0.3, 1.5, 4);\nconst fuselageMat = new THREE.MeshPhongMaterial({ color: 0x00ff00, emissive: 0x003300 });\nconst fuselage = new THREE.Mesh(fuselageGeom, fuselageMat);\nfuselage.rotation.x = Math.PI / 2;\nshipGeometry.add(fuselage);\n\n// Wings\nconst wingGeom = new THREE.BoxGeometry(3, 0.1, 0.8);\nconst wingMat = new THREE.MeshPhongMaterial({ color: 0x00cc00, emissive: 0x002200 });\nconst wings = new THREE.Mesh(wingGeom, wingMat);\nwings.position.z = -0.2;\nshipGeometry.add(wings);\n\n// Cockpit\nconst cockpitGeom = new THREE.SphereGeometry(0.2, 8, 8);\nconst cockpitMat = new THREE.MeshPhongMaterial({ color: 0x00ffff, emissive: 0x0088ff, transparent: true, opacity: 0.8 });\nconst cockpit = new THREE.Mesh(cockpitGeom, cockpitMat);\ncockpit.position.z = 0.5;\ncockpit.scale.z = 1.5;\nshipGeometry.add(cockpit);\n\n// Engine glow\nconst engineGeom = new THREE.SphereGeometry(0.15, 8, 8);\nconst engineMat = new THREE.MeshBasicMaterial({ color: 0xff4400 });\nconst engineL = new THREE.Mesh(engineGeom, engineMat);\nengineL.position.set(-1.2, 0, -0.5);\nconst engineR = new THREE.Mesh(engineGeom, engineMat);\nengineR.position.set(1.2, 0, -0.5);\nshipGeometry.add(engineL, engineR);\n\nplayerGroup.add(shipGeometry);\nscene.add(playerGroup);\n\n// Player state\nconst player = {\n  group: playerGroup,\n  x: 0,\n  y: 0,\n  targetX: 0,\n  targetY: 0,\n  pitch: 0,\n  roll: 0,\n  targetPitch: 0,\n  targetRoll: 0,\n  boundX: 8,\n  boundY: 5\n};\n\n// ==================== PROJECTILES ====================\nconst projectiles = [];\nconst enemyProjectiles = [];\n\nfunction createLaser(x, y, z, isEnemy = false) {\n  const geometry = new THREE.CylinderGeometry(0.05, 0.05, 0.8);\n  const material = new THREE.MeshBasicMaterial({ \n    color: isEnemy ? 0xff0000 : 0x00ffff,\n    emissive: isEnemy ? 0xff0000 : 0x00ffff\n  });\n  const laser = new THREE.Mesh(geometry, material);\n  laser.rotation.x = Math.PI / 2;\n  laser.position.set(x, y, z);\n  scene.add(laser);\n  \n  const projectile = {\n    mesh: laser,\n    velocity: isEnemy ? 0.8 : -1.2\n  };\n  \n  if (isEnemy) {\n    enemyProjectiles.push(projectile);\n  } else {\n    projectiles.push(projectile);\n  }\n}\n\nlet shootCooldown = 0;\n\nfunction shoot() {\n  if (shootCooldown <= 0 && !gameState.isGameOver) {\n    createLaser(player.x - 0.3, player.y, player.group.position.z - 1, false);\n    createLaser(player.x + 0.3, player.y, player.group.position.z - 1, false);\n    shootCooldown = 8;\n  }\n}\n\nfunction useBomb() {\n  if (gameState.bombs > 0 && !gameState.isGameOver) {\n    gameState.bombs--;\n    document.getElementById('bombs').textContent = gameState.bombs;\n    \n    // Clear all nearby enemies and projectiles\n    enemies.forEach(enemy => {\n      if (Math.abs(enemy.mesh.position.z - player.group.position.z) < 30) {\n        enemy.health = 0;\n      }\n    });\n    \n    enemyProjectiles.forEach(proj => {\n      scene.remove(proj.mesh);\n    });\n    enemyProjectiles.length = 0;\n    \n    // Visual effect\n    const bombGeom = new THREE.SphereGeometry(15, 16, 16);\n    const bombMat = new THREE.MeshBasicMaterial({ \n      color: 0xffff00,\n      transparent: true,\n      opacity: 0.6\n    });\n    const bombBlast = new THREE.Mesh(bombGeom, bombMat);\n    bombBlast.position.copy(player.group.position);\n    scene.add(bombBlast);\n    \n    setTimeout(() => scene.remove(bombBlast), 200);\n  }\n}\n\n// ==================== ENEMIES ====================\nconst enemies = [];\n\nfunction createEnemy(x, y, z, type = 'fighter') {\n  const geometry = type === 'fighter' \n    ? new THREE.OctahedronGeometry(0.5)\n    : new THREE.DodecahedronGeometry(0.8);\n  const material = new THREE.MeshPhongMaterial({ \n    color: 0xff0000,\n    emissive: 0x440000\n  });\n  const mesh = new THREE.Mesh(geometry, material);\n  mesh.position.set(x, y, z);\n  scene.add(mesh);\n  \n  const enemy = {\n    mesh,\n    health: type === 'fighter' ? 2 : 4,\n    type,\n    pathT: 0,\n    startX: x,\n    startY: y,\n    shootTimer: Math.random() * 100\n  };\n  \n  enemies.push(enemy);\n}\n\n// ==================== BOSS ====================\nlet boss = null;\n\nfunction createBoss() {\n  const bossGroup = new THREE.Group();\n  \n  // Core body\n  const coreGeom = new THREE.SphereGeometry(2, 16, 16);\n  const coreMat = new THREE.MeshPhongMaterial({ \n    color: 0x880000,\n    emissive: 0x440000\n  });\n  const core = new THREE.Mesh(coreGeom, coreMat);\n  bossGroup.add(core);\n  \n  // Weak points\n  const weakPoints = [];\n  for (let i = 0; i < 4; i++) {\n    const angle = (i / 4) * Math.PI * 2;\n    const wpGeom = new THREE.SphereGeometry(0.5, 8, 8);\n    const wpMat = new THREE.MeshBasicMaterial({ color: 0xff00ff, emissive: 0xff00ff });\n    const wp = new THREE.Mesh(wpGeom, wpMat);\n    wp.position.set(Math.cos(angle) * 2.5, Math.sin(angle) * 2.5, 0);\n    bossGroup.add(wp);\n    weakPoints.push({ mesh: wp, health: 10, destroyed: false });\n  }\n  \n  bossGroup.position.set(0, 0, player.group.position.z - 30);\n  scene.add(bossGroup);\n  \n  boss = {\n    group: bossGroup,\n    core,\n    weakPoints,\n    health: 100,\n    phase: 1,\n    shootTimer: 0,\n    moveTimer: 0\n  };\n  \n  gameState.inBossFight = true;\n  gameState.forwardSpeed = 0; // Stop rail scrolling\n}\n\n// ==================== OBSTACLES ====================\nconst obstacles = [];\n\nfunction createObstacle(x, y, z, type = 'asteroid') {\n  const geometry = type === 'asteroid'\n    ? new THREE.DodecahedronGeometry(1.5)\n    : new THREE.TorusGeometry(3, 0.5, 8, 16);\n    \n  const material = new THREE.MeshPhongMaterial({ \n    color: type === 'asteroid' ? 0x888888 : 0x444444,\n    emissive: 0x222222\n  });\n  const mesh = new THREE.Mesh(geometry, material);\n  mesh.position.set(x, y, z);\n  mesh.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, Math.random() * Math.PI);\n  scene.add(mesh);\n  \n  obstacles.push({\n    mesh,\n    type,\n    rotationSpeed: { x: (Math.random() - 0.5) * 0.02, y: (Math.random() - 0.5) * 0.02 }\n  });\n}\n\n// ==================== STARFIELD ====================\nconst stars = [];\nfor (let i = 0; i < 500; i++) {\n  const starGeom = new THREE.SphereGeometry(0.1, 4, 4);\n  const starMat = new THREE.MeshBasicMaterial({ color: 0xffffff });\n  const star = new THREE.Mesh(starGeom, starMat);\n  star.position.set(\n    (Math.random() - 0.5) * 200,\n    (Math.random() - 0.5) * 200,\n    (Math.random() - 0.5) * 200 - 100\n  );\n  scene.add(star);\n  stars.push(star);\n}\n\n// ==================== LEVEL GENERATION ====================\nfunction spawnWave(z) {\n  const waveType = Math.floor(Math.random() * 3);\n  \n  if (waveType === 0) {\n    // V Formation\n    for (let i = 0; i < 5; i++) {\n      createEnemy((i - 2) * 2, Math.abs(i - 2), z - i * 3, 'fighter');\n    }\n  } else if (waveType === 1) {\n    // Circle\n    for (let i = 0; i < 6; i++) {\n      const angle = (i / 6) * Math.PI * 2;\n      createEnemy(Math.cos(angle) * 4, Math.sin(angle) * 3, z, 'heavy');\n    }\n  } else {\n    // Random spread\n    for (let i = 0; i < 8; i++) {\n      createEnemy(\n        (Math.random() - 0.5) * 12,\n        (Math.random() - 0.5) * 8,\n        z - Math.random() * 10,\n        Math.random() > 0.5 ? 'fighter' : 'heavy'\n      );\n    }\n  }\n}\n\nfunction spawnObstacles(z) {\n  const obstacleType = Math.floor(Math.random() * 2);\n  \n  if (obstacleType === 0) {\n    // Asteroid field\n    for (let i = 0; i < 5; i++) {\n      createObstacle(\n        (Math.random() - 0.5) * 16,\n        (Math.random() - 0.5) * 10,\n        z - Math.random() * 20,\n        'asteroid'\n      );\n    }\n  } else {\n    // Ring gate\n    createObstacle(0, 0, z, 'ring');\n  }\n}\n\n// Initial level population\nfor (let i = 0; i < 5; i++) {\n  spawnWave(-30 - i * 40);\n  spawnObstacles(-50 - i * 40);\n}\n\n// ==================== INPUT HANDLING ====================\ndocument.addEventListener('keydown', (e) => {\n  keys[e.key] = true;\n  \n  // Barrel roll detection\n  if (e.key === 'ArrowLeft' || e.key === 'a') {\n    const now = Date.now();\n    if (now - gameState.lastTapTime.left < 300 && gameState.rollCooldown <= 0) {\n      initiateBarrelRoll(-1);\n    }\n    gameState.lastTapTime.left = now;\n  }\n  if (e.key === 'ArrowRight' || e.key === 'd') {\n    const now = Date.now();\n    if (now - gameState.lastTapTime.right < 300 && gameState.rollCooldown <= 0) {\n      initiateBarrelRoll(1);\n    }\n    gameState.lastTapTime.right = now;\n  }\n  \n  if (e.key === ' ') shoot();\n  if (e.key === 'b' || e.key === 'B') useBomb();\n});\n\ndocument.addEventListener('keyup', (e) => {\n  keys[e.key] = false;\n});\n\n// Mobile controls\nfunction setupMobileControls() {\n  const dpadBtns = {\n    btnUp: 'up',\n    btnDown: 'down',\n    btnLeft: 'left',\n    btnRight: 'right'\n  };\n  \n  Object.keys(dpadBtns).forEach(btnId => {\n    const btn = document.getElementById(btnId);\n    const dir = dpadBtns[btnId];\n    \n    btn.addEventListener('touchstart', (e) => {\n      e.preventDefault();\n      mobileInput[dir] = true;\n      btn.classList.add('active');\n    });\n    \n    btn.addEventListener('touchend', (e) => {\n      e.preventDefault();\n      mobileInput[dir] = false;\n      btn.classList.remove('active');\n    });\n  });\n  \n  // A button - Shoot\n  const btnA = document.getElementById('btnA');\n  btnA.addEventListener('touchstart', (e) => {\n    e.preventDefault();\n    mobileInput.shoot = true;\n    btnA.classList.add('active');\n  });\n  btnA.addEventListener('touchend', (e) => {\n    e.preventDefault();\n    mobileInput.shoot = false;\n    btnA.classList.remove('active');\n  });\n  \n  // B button - Bomb\n  const btnB = document.getElementById('btnB');\n  btnB.addEventListener('touchstart', (e) => {\n    e.preventDefault();\n    useBomb();\n    btnB.classList.add('active');\n    setTimeout(() => btnB.classList.remove('active'), 200);\n  });\n  \n  // C button - Barrel Roll\n  const btnC = document.getElementById('btnC');\n  btnC.addEventListener('touchstart', (e) => {\n    e.preventDefault();\n    if (gameState.rollCooldown <= 0) {\n      initiateBarrelRoll(1);\n      btnC.classList.add('active');\n      setTimeout(() => btnC.classList.remove('active'), 200);\n    }\n  });\n}\n\nsetupMobileControls();\n\nfunction initiateBarrelRoll(direction) {\n  gameState.isRolling = true;\n  gameState.rollDirection = direction;\n  gameState.rollCooldown = 120;\n  gameState.invincible = true;\n  \n  setTimeout(() => {\n    gameState.isRolling = false;\n    gameState.invincible = false;\n  }, 500);\n}\n\n// ==================== COLLISION DETECTION ====================\nfunction checkCollision(obj1Pos, obj1Radius, obj2Pos, obj2Radius) {\n  const dx = obj1Pos.x - obj2Pos.x;\n  const dy = obj1Pos.y - obj2Pos.y;\n  const dz = obj1Pos.z - obj2Pos.z;\n  const distance = Math.sqrt(dx * dx + dy * dy + dz * dz);\n  return distance < (obj1Radius + obj2Radius);\n}\n\nfunction takeDamage(amount) {\n  if (!gameState.invincible && !gameState.isGameOver) {\n    gameState.health -= amount;\n    document.getElementById('health').textContent = Math.max(0, gameState.health);\n    \n    if (gameState.health <= 0) {\n      endGame(false);\n    }\n  }\n}\n\n// ==================== UPDATE FUNCTIONS ====================\nfunction updatePlayer() {\n  // Handle input\n  let inputX = 0;\n  let inputY = 0;\n  \n  if (keys['ArrowLeft'] || keys['a'] || mobileInput.left) inputX -= 1;\n  if (keys['ArrowRight'] || keys['d'] || mobileInput.right) inputX += 1;\n  if (keys['ArrowUp'] || keys['w'] || mobileInput.up) inputY += 1;\n  if (keys['ArrowDown'] || keys['s'] || mobileInput.down) inputY -= 1;\n  \n  if (mobileInput.shoot) shoot();\n  \n  // Barrel roll movement\n  if (gameState.isRolling) {\n    inputX = gameState.rollDirection * 2;\n  }\n  \n  // Update target position\n  const speed = 0.25;\n  player.targetX += inputX * speed;\n  player.targetY += inputY * speed;\n  \n  // Clamp to bounds\n  player.targetX = Math.max(-player.boundX, Math.min(player.boundX, player.targetX));\n  player.targetY = Math.max(-player.boundY, Math.min(player.boundY, player.targetY));\n  \n  // Smooth movement\n  player.x += (player.targetX - player.x) * 0.15;\n  player.y += (player.targetY - player.y) * 0.15;\n  \n  // Update ship rotation (pitch and roll)\n  player.targetPitch = -inputY * 0.3;\n  player.targetRoll = -inputX * 0.5;\n  \n  if (gameState.isRolling) {\n    player.targetRoll = gameState.rollDirection * Math.PI * 2;\n  }\n  \n  player.pitch += (player.targetPitch - player.pitch) * 0.1;\n  player.roll += (player.targetRoll - player.roll) * 0.1;\n  \n  if (!gameState.isRolling) {\n    player.roll *= 0.95; // Decay roll when not rolling\n  }\n  \n  player.group.position.x = player.x;\n  player.group.position.y = player.y;\n  player.group.rotation.x = player.pitch;\n  player.group.rotation.z = player.roll;\n  \n  // Update crosshair\n  const crosshair = document.getElementById('crosshair');\n  const screenX = (player.x / player.boundX) * (window.innerWidth / 4) + window.innerWidth / 2;\n  const screenY = -(player.y / player.boundY) * (window.innerHeight / 4) + window.innerHeight / 2;\n  crosshair.style.left = (screenX - 20) + 'px';\n  crosshair.style.top = (screenY - 20) + 'px';\n  \n  // Cooldowns\n  if (shootCooldown > 0) shootCooldown--;\n  if (gameState.rollCooldown > 0) gameState.rollCooldown--;\n}\n\nfunction updateProjectiles() {\n  // Player projectiles\n  for (let i = projectiles.length - 1; i >= 0; i--) {\n    const proj = projectiles[i];\n    proj.mesh.position.z += proj.velocity;\n    \n    // Remove if out of range\n    if (proj.mesh.position.z < player.group.position.z - 100) {\n      scene.remove(proj.mesh);\n      projectiles.splice(i, 1);\n      continue;\n    }\n    \n    // Check enemy hits\n    for (let j = enemies.length - 1; j >= 0; j--) {\n      const enemy = enemies[j];\n      if (checkCollision(proj.mesh.position, 0.5, enemy.mesh.position, 1)) {\n        enemy.health--;\n        scene.remove(proj.mesh);\n        projectiles.splice(i, 1);\n        \n        if (enemy.health <= 0) {\n          scene.remove(enemy.mesh);\n          enemies.splice(j, 1);\n          gameState.score += 100;\n          document.getElementById('score').textContent = gameState.score;\n        }\n        break;\n      }\n    }\n    \n    // Check boss hits\n    if (boss && !gameState.bossDefeated) {\n      boss.weakPoints.forEach(wp => {\n        if (!wp.destroyed && checkCollision(proj.mesh.position, 0.5, wp.mesh.position, 0.5)) {\n          wp.health--;\n          scene.remove(proj.mesh);\n          projectiles.splice(i, 1);\n          \n          if (wp.health <= 0) {\n            wp.destroyed = true;\n            scene.remove(wp.mesh);\n            gameState.score += 500;\n            document.getElementById('score').textContent = gameState.score;\n            \n            // Check if all weak points destroyed\n            if (boss.weakPoints.every(w => w.destroyed)) {\n              gameState.bossDefeated = true;\n              setTimeout(() => endGame(true), 2000);\n            }\n          }\n        }\n      });\n    }\n  }\n  \n  // Enemy projectiles\n  for (let i = enemyProjectiles.length - 1; i >= 0; i--) {\n    const proj = enemyProjectiles[i];\n    proj.mesh.position.z += proj.velocity;\n    \n    if (proj.mesh.position.z > player.group.position.z + 20) {\n      scene.remove(proj.mesh);\n      enemyProjectiles.splice(i, 1);\n      continue;\n    }\n    \n    // Check player hit\n    if (checkCollision(proj.mesh.position, 0.3, player.group.position, 0.8)) {\n      if (gameState.isRolling) {\n        // Deflect projectile\n        scene.remove(proj.mesh);\n        enemyProjectiles.splice(i, 1);\n      } else {\n        takeDamage(5);\n        scene.remove(proj.mesh);\n        enemyProjectiles.splice(i, 1);\n      }\n    }\n  }\n}\n\nfunction updateEnemies() {\n  for (let i = enemies.length - 1; i >= 0; i--) {\n    const enemy = enemies[i];\n    \n    // Bezier curve flight path\n    enemy.pathT += 0.01;\n    const t = enemy.pathT;\n    const amplitude = 3;\n    enemy.mesh.position.x = enemy.startX + Math.sin(t * 2) * amplitude;\n    enemy.mesh.position.y = enemy.startY + Math.cos(t * 3) * amplitude * 0.5;\n    \n    enemy.mesh.rotation.y += 0.02;\n    \n    // Shoot at player\n    enemy.shootTimer++;\n    if (enemy.shootTimer > 120 && Math.abs(enemy.mesh.position.z - player.group.position.z) < 40) {\n      const dx = player.x - enemy.mesh.position.x;\n      const dy = player.y - enemy.mesh.position.y;\n      const angle = Math.atan2(dy, dx);\n      \n      createLaser(\n        enemy.mesh.position.x + Math.cos(angle) * 0.5,\n        enemy.mesh.position.y + Math.sin(angle) * 0.5,\n        enemy.mesh.position.z,\n        true\n      );\n      enemy.shootTimer = 0;\n    }\n    \n    // Remove if behind player\n    if (enemy.mesh.position.z > player.group.position.z + 20) {\n      scene.remove(enemy.mesh);\n      enemies.splice(i, 1);\n    }\n    \n    // Check collision with player\n    if (checkCollision(enemy.mesh.position, 1, player.group.position, 0.8)) {\n      takeDamage(20);\n      enemy.health = 0;\n      scene.remove(enemy.mesh);\n      enemies.splice(i, 1);\n    }\n  }\n}\n\nfunction updateObstacles() {\n  for (let i = obstacles.length - 1; i >= 0; i--) {\n    const obs = obstacles[i];\n    \n    obs.mesh.rotation.x += obs.rotationSpeed.x;\n    obs.mesh.rotation.y += obs.rotationSpeed.y;\n    \n    // Remove if behind player\n    if (obs.mesh.position.z > player.group.position.z + 20) {\n      scene.remove(obs.mesh);\n      obstacles.splice(i, 1);\n      continue;\n    }\n    \n    // Check collision with player\n    const collisionRadius = obs.type === 'asteroid' ? 1.5 : 0; // Can fly through ring center\n    if (obs.type === 'asteroid' && checkCollision(obs.mesh.position, collisionRadius, player.group.position, 0.8)) {\n      takeDamage(30);\n      scene.remove(obs.mesh);\n      obstacles.splice(i, 1);\n    } else if (obs.type === 'ring') {\n      // Check if player is in ring plane but not in center\n      const dz = Math.abs(obs.mesh.position.z - player.group.position.z);\n      if (dz < 0.5) {\n        const dx = player.group.position.x - obs.mesh.position.x;\n        const dy = player.group.position.y - obs.mesh.position.y;\n        const distFromCenter = Math.sqrt(dx * dx + dy * dy);\n        if (distFromCenter > 2.5 && distFromCenter < 4) {\n          takeDamage(50);\n        }\n      }\n    }\n  }\n}\n\nfunction updateBoss() {\n  if (!boss || gameState.bossDefeated) return;\n  \n  boss.moveTimer++;\n  \n  // Boss movement pattern\n  const t = boss.moveTimer * 0.02;\n  boss.group.position.x = Math.sin(t) * 5;\n  boss.group.position.y = Math.cos(t * 0.7) * 3;\n  \n  boss.core.rotation.y += 0.01;\n  \n  // Boss attacks\n  boss.shootTimer++;\n  if (boss.shootTimer > 60) {\n    // Spread shot\n    for (let i = -2; i <= 2; i++) {\n      createLaser(\n        boss.group.position.x + i * 0.5,\n        boss.group.position.y,\n        boss.group.position.z,\n        true\n      );\n    }\n    boss.shootTimer = 0;\n  }\n}\n\nfunction updateStarfield() {\n  stars.forEach(star => {\n    star.position.z += gameState.forwardSpeed * 2;\n    if (star.position.z > player.group.position.z + 20) {\n      star.position.z -= 220;\n    }\n  });\n}\n\nfunction updateLevelGeneration() {\n  gameState.zPosition += gameState.forwardSpeed;\n  \n  // Spawn new waves\n  if (Math.floor(gameState.zPosition) % 40 === 0 && !gameState.inBossFight) {\n    const spawnZ = player.group.position.z - 80;\n    if (Math.random() > 0.5) {\n      spawnWave(spawnZ);\n    } else {\n      spawnObstacles(spawnZ);\n    }\n  }\n  \n  // Trigger boss fight\n  if (gameState.zPosition > 300 && !boss && !gameState.bossDefeated) {\n    createBoss();\n  }\n}\n\n// ==================== GAME OVER ====================\nfunction endGame(victory) {\n  gameState.isGameOver = true;\n  \n  const gameOverDiv = document.getElementById('gameOver');\n  const statusText = document.getElementById('statusText');\n  const finalScore = document.getElementById('finalScore');\n  \n  finalScore.textContent = gameState.score;\n  \n  if (victory) {\n    statusText.textContent = 'MISSION COMPLETE!';\n    gameOverDiv.querySelector('h1').textContent = 'VICTORY!';\n  } else {\n    statusText.textContent = 'MISSION FAILED';\n    gameOverDiv.querySelector('h1').textContent = 'GAME OVER';\n  }\n  \n  gameOverDiv.style.display = 'block';\n}\n\ndocument.getElementById('restartBtn').addEventListener('click', () => {\n  location.reload();\n});\n\n// ==================== GAME LOOP ====================\nfunction gameLoop() {\n  if (!gameState.isGameOver) {\n    updatePlayer();\n    updateProjectiles();\n    updateEnemies();\n    updateObstacles();\n    updateBoss();\n    updateStarfield();\n    updateLevelGeneration();\n    \n    // Move camera forward\n    if (!gameState.inBossFight) {\n      player.group.position.z -= gameState.forwardSpeed;\n      camera.position.z = player.group.position.z + 5;\n    }\n  }\n  \n  renderer.render(scene, camera);\n  requestAnimationFrame(gameLoop);\n}\n\n// Handle window resize\nwindow.addEventListener('resize', () => {\n  camera.aspect = window.innerWidth / window.innerHeight;\n  camera.updateProjectionMatrix();\n  renderer.setSize(window.innerWidth, window.innerHeight);\n});\n\n// ==================== START GAME ====================\ngameLoop();\n</script>\n\n</body>\n</html>"
}
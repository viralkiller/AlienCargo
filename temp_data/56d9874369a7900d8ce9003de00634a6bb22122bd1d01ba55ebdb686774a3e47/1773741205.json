    "prompt": "Tetris but goes bottom up",
    "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\">\n<title>Reverse Tetris</title>\n<style>\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n  -webkit-touch-callout: none;\n  -webkit-user-select: none;\n  user-select: none;\n}\n\nbody {\n  width: 100vw;\n  height: 100vh;\n  overflow: hidden;\n  background: linear-gradient(180deg, #0a0a1a 0%, #1a1a2e 100%);\n  font-family: 'Arial', sans-serif;\n  display: flex;\n  flex-direction: column;\n  touch-action: none;\n}\n\n#gameContainer {\n  flex: 1;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  position: relative;\n}\n\ncanvas {\n  border: 3px solid #4a4aff;\n  box-shadow: 0 0 30px rgba(74, 74, 255, 0.5);\n  background: #000;\n  image-rendering: pixelated;\n  image-rendering: crisp-edges;\n}\n\n#ui {\n  position: absolute;\n  top: 20px;\n  right: 20px;\n  color: #fff;\n  text-align: right;\n  font-size: 18px;\n  text-shadow: 2px 2px 4px #000;\n  pointer-events: none;\n}\n\n#gameOver {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  background: rgba(0, 0, 0, 0.95);\n  padding: 40px;\n  border-radius: 15px;\n  text-align: center;\n  color: #fff;\n  display: none;\n  border: 3px solid #ff4a4a;\n  box-shadow: 0 0 40px rgba(255, 74, 74, 0.8);\n  z-index: 1000;\n}\n\n#gameOver h1 {\n  font-size: 48px;\n  margin-bottom: 20px;\n  color: #ff4a4a;\n}\n\n#gameOver p {\n  font-size: 24px;\n  margin: 10px 0;\n}\n\n#restartBtn {\n  margin-top: 30px;\n  padding: 15px 40px;\n  font-size: 24px;\n  background: linear-gradient(135deg, #4a4aff, #ff4aff);\n  color: #fff;\n  border: none;\n  border-radius: 10px;\n  cursor: pointer;\n  font-weight: bold;\n  transition: transform 0.2s, box-shadow 0.2s;\n  pointer-events: auto;\n}\n\n#restartBtn:hover {\n  transform: scale(1.1);\n  box-shadow: 0 0 20px rgba(255, 74, 255, 0.8);\n}\n\n#restartBtn:active {\n  transform: scale(0.95);\n}\n\n#mobileControls {\n  display: none;\n  width: 100%;\n  height: 200px;\n  background: rgba(20, 20, 40, 0.9);\n  border-top: 2px solid #4a4aff;\n}\n\n@media (max-width: 768px), (pointer: coarse) {\n  #mobileControls {\n    display: grid;\n    grid-template-columns: 1fr 1fr 1fr;\n    grid-template-rows: 1fr 1fr;\n    gap: 10px;\n    padding: 10px;\n  }\n}\n\n.control-btn {\n  background: rgba(74, 74, 255, 0.3);\n  border: 2px solid #4a4aff;\n  border-radius: 10px;\n  color: #fff;\n  font-size: 20px;\n  font-weight: bold;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  cursor: pointer;\n  transition: all 0.1s;\n  touch-action: none;\n  -webkit-tap-highlight-color: transparent;\n}\n\n.control-btn:active {\n  background: rgba(74, 74, 255, 0.7);\n  transform: scale(0.95);\n}\n\n.dpad-container {\n  grid-column: 1;\n  grid-row: 1 / 3;\n  display: grid;\n  grid-template-columns: 1fr 1fr 1fr;\n  grid-template-rows: 1fr 1fr 1fr;\n  gap: 5px;\n}\n\n.dpad-btn {\n  background: rgba(74, 74, 255, 0.3);\n  border: 2px solid #4a4aff;\n  border-radius: 8px;\n  color: #fff;\n  font-size: 24px;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  cursor: pointer;\n  touch-action: none;\n  -webkit-tap-highlight-color: transparent;\n}\n\n.dpad-btn:active {\n  background: rgba(74, 74, 255, 0.7);\n  transform: scale(0.95);\n}\n\n#dpadUp { grid-column: 2; grid-row: 1; }\n#dpadDown { grid-column: 2; grid-row: 3; }\n#dpadLeft { grid-column: 1; grid-row: 2; }\n#dpadRight { grid-column: 3; grid-row: 2; }\n\n.action-container {\n  grid-column: 3;\n  grid-row: 1 / 3;\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  grid-template-rows: 1fr 1fr;\n  gap: 5px;\n}\n\n#btnA {\n  grid-column: 2;\n  grid-row: 2;\n  background: rgba(255, 74, 74, 0.3);\n  border-color: #ff4a4a;\n}\n\n#btnA:active {\n  background: rgba(255, 74, 74, 0.7);\n}\n\n#btnB {\n  grid-column: 1;\n  grid-row: 1;\n  background: rgba(74, 255, 74, 0.3);\n  border-color: #4aff4a;\n}\n\n#btnB:active {\n  background: rgba(74, 255, 74, 0.7);\n}\n\n#btnC {\n  grid-column: 2;\n  grid-row: 1;\n  background: rgba(255, 255, 74, 0.3);\n  border-color: #ffff4a;\n}\n\n#btnC:active {\n  background: rgba(255, 255, 74, 0.7);\n}\n</style>\n</head>\n<body>\n\n<div id=\"gameContainer\">\n  <canvas id=\"gameCanvas\"></canvas>\n  \n  <div id=\"ui\">\n    <div>Score: <span id=\"score\">0</span></div>\n    <div>Lines: <span id=\"lines\">0</span></div>\n    <div>Level: <span id=\"level\">1</span></div>\n  </div>\n\n  <div id=\"gameOver\">\n    <h1>GAME OVER</h1>\n    <p>Final Score: <span id=\"finalScore\">0</span></p>\n    <p>Lines Cleared: <span id=\"finalLines\">0</span></p>\n    <button id=\"restartBtn\">RESTART</button>\n  </div>\n</div>\n\n<div id=\"mobileControls\">\n  <div class=\"dpad-container\">\n    <div class=\"dpad-btn\" id=\"dpadUp\">\u25b2</div>\n    <div class=\"dpad-btn\" id=\"dpadLeft\">\u25c4</div>\n    <div class=\"dpad-btn\" id=\"dpadRight\">\u25ba</div>\n    <div class=\"dpad-btn\" id=\"dpadDown\">\u25bc</div>\n  </div>\n  \n  <div style=\"grid-column: 2; grid-row: 1 / 3;\"></div>\n  \n  <div class=\"action-container\">\n    <div class=\"control-btn\" id=\"btnB\">ROTATE</div>\n    <div class=\"control-btn\" id=\"btnC\">HOLD</div>\n    <div class=\"control-btn\" id=\"btnA\">DROP</div>\n  </div>\n</div>\n\n<script>\n// Game Configuration\nconst COLS = 10;\nconst ROWS = 20;\nconst BLOCK_SIZE = 30;\nconst COLORS = [\n  '#00f0f0', // I - Cyan\n  '#f0f000', // O - Yellow\n  '#a000f0', // T - Purple\n  '#00f000', // S - Green\n  '#f00000', // Z - Red\n  '#0000f0', // J - Blue\n  '#f0a000'  // L - Orange\n];\n\nconst SHAPES = [\n  [[1,1,1,1]], // I\n  [[1,1],[1,1]], // O\n  [[0,1,0],[1,1,1]], // T\n  [[0,1,1],[1,1,0]], // S\n  [[1,1,0],[0,1,1]], // Z\n  [[1,0,0],[1,1,1]], // J\n  [[0,0,1],[1,1,1]]  // L\n];\n\n// Canvas Setup\nconst canvas = document.getElementById('gameCanvas');\nconst ctx = canvas.getContext('2d');\ncanvas.width = COLS * BLOCK_SIZE;\ncanvas.height = ROWS * BLOCK_SIZE;\n\n// Game State\nlet board = [];\nlet currentPiece = null;\nlet currentX = 0;\nlet currentY = 0;\nlet score = 0;\nlet lines = 0;\nlet level = 1;\nlet gameRunning = true;\nlet dropCounter = 0;\nlet dropInterval = 1000;\nlet lastTime = 0;\nlet heldPiece = null;\nlet canHold = true;\n\n// Input State\nlet keys = {};\nlet moveCounter = 0;\nlet moveDelay = 150;\nlet lastMoveTime = 0;\n\n// Initialize Board\nfunction initBoard() {\n  board = Array(ROWS).fill(null).map(() => Array(COLS).fill(0));\n}\n\n// Create New Piece\nfunction createPiece() {\n  const type = Math.floor(Math.random() * SHAPES.length);\n  const shape = SHAPES[type];\n  const color = COLORS[type];\n  return { shape, color, type };\n}\n\n// Spawn Piece (from BOTTOM)\nfunction spawnPiece() {\n  currentPiece = createPiece();\n  currentX = Math.floor(COLS / 2) - Math.floor(currentPiece.shape[0].length / 2);\n  // Start at BOTTOM instead of top\n  currentY = ROWS - currentPiece.shape.length;\n  canHold = true;\n  \n  if (collision(currentPiece, currentX, currentY)) {\n    gameOver();\n  }\n}\n\n// Collision Detection\nfunction collision(piece, x, y) {\n  for (let row = 0; row < piece.shape.length; row++) {\n    for (let col = 0; col < piece.shape[row].length; col++) {\n      if (piece.shape[row][col]) {\n        const newX = x + col;\n        const newY = y + row;\n        \n        if (newX < 0 || newX >= COLS || newY < 0 || newY >= ROWS) {\n          return true;\n        }\n        \n        if (board[newY][newX]) {\n          return true;\n        }\n      }\n    }\n  }\n  return false;\n}\n\n// Merge Piece to Board\nfunction mergePiece() {\n  for (let row = 0; row < currentPiece.shape.length; row++) {\n    for (let col = 0; col < currentPiece.shape[row].length; col++) {\n      if (currentPiece.shape[row][col]) {\n        const y = currentY + row;\n        const x = currentX + col;\n        if (y >= 0 && y < ROWS) {\n          board[y][x] = currentPiece.color;\n        }\n      }\n    }\n  }\n}\n\n// Clear Lines (from TOP in reverse tetris)\nfunction clearLines() {\n  let linesCleared = 0;\n  \n  // Check from TOP to BOTTOM\n  for (let row = 0; row < ROWS; row++) {\n    if (board[row].every(cell => cell !== 0)) {\n      // Remove the line\n      board.splice(row, 1);\n      // Add empty line at BOTTOM\n      board.push(Array(COLS).fill(0));\n      linesCleared++;\n    }\n  }\n  \n  if (linesCleared > 0) {\n    lines += linesCleared;\n    score += [0, 100, 300, 500, 800][linesCleared] * level;\n    level = Math.floor(lines / 10) + 1;\n    dropInterval = Math.max(100, 1000 - (level - 1) * 100);\n    \n    document.getElementById('score').textContent = score;\n    document.getElementById('lines').textContent = lines;\n    document.getElementById('level').textContent = level;\n  }\n}\n\n// Rotate Piece\nfunction rotate(piece) {\n  const newShape = piece.shape[0].map((_, i) =>\n    piece.shape.map(row => row[i]).reverse()\n  );\n  return { ...piece, shape: newShape };\n}\n\n// Move Piece\nfunction move(dx, dy) {\n  const newX = currentX + dx;\n  const newY = currentY + dy;\n  \n  if (!collision(currentPiece, newX, newY)) {\n    currentX = newX;\n    currentY = newY;\n    return true;\n  }\n  return false;\n}\n\n// Hard Drop\nfunction hardDrop() {\n  // In reverse tetris, drop means move UP\n  while (move(0, -1)) {}\n  mergePiece();\n  clearLines();\n  spawnPiece();\n  dropCounter = 0;\n}\n\n// Hold Piece\nfunction holdPiece() {\n  if (!canHold) return;\n  \n  if (heldPiece === null) {\n    heldPiece = currentPiece;\n    spawnPiece();\n  } else {\n    const temp = currentPiece;\n    currentPiece = heldPiece;\n    heldPiece = temp;\n    currentX = Math.floor(COLS / 2) - Math.floor(currentPiece.shape[0].length / 2);\n    currentY = ROWS - currentPiece.shape.length;\n  }\n  \n  canHold = false;\n}\n\n// Draw Functions\nfunction drawBlock(x, y, color) {\n  ctx.fillStyle = color;\n  ctx.fillRect(x * BLOCK_SIZE, y * BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE);\n  ctx.strokeStyle = '#000';\n  ctx.lineWidth = 2;\n  ctx.strokeRect(x * BLOCK_SIZE, y * BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE);\n  \n  // Shine effect\n  ctx.fillStyle = 'rgba(255, 255, 255, 0.3)';\n  ctx.fillRect(x * BLOCK_SIZE + 2, y * BLOCK_SIZE + 2, BLOCK_SIZE - 4, BLOCK_SIZE / 3);\n}\n\nfunction drawBoard() {\n  ctx.fillStyle = '#000';\n  ctx.fillRect(0, 0, canvas.width, canvas.height);\n  \n  // Draw grid\n  ctx.strokeStyle = '#222';\n  ctx.lineWidth = 1;\n  for (let row = 0; row < ROWS; row++) {\n    for (let col = 0; col < COLS; col++) {\n      ctx.strokeRect(col * BLOCK_SIZE, row * BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE);\n    }\n  }\n  \n  // Draw placed blocks\n  for (let row = 0; row < ROWS; row++) {\n    for (let col = 0; col < COLS; col++) {\n      if (board[row][col]) {\n        drawBlock(col, row, board[row][col]);\n      }\n    }\n  }\n}\n\nfunction drawPiece() {\n  if (!currentPiece) return;\n  \n  for (let row = 0; row < currentPiece.shape.length; row++) {\n    for (let col = 0; col < currentPiece.shape[row].length; col++) {\n      if (currentPiece.shape[row][col]) {\n        drawBlock(currentX + col, currentY + row, currentPiece.color);\n      }\n    }\n  }\n  \n  // Draw ghost piece (shows where it will land at TOP)\n  let ghostY = currentY;\n  while (!collision(currentPiece, currentX, ghostY - 1)) {\n    ghostY--;\n  }\n  \n  if (ghostY !== currentY) {\n    ctx.globalAlpha = 0.3;\n    for (let row = 0; row < currentPiece.shape.length; row++) {\n      for (let col = 0; col < currentPiece.shape[row].length; col++) {\n        if (currentPiece.shape[row][col]) {\n          drawBlock(currentX + col, ghostY + row, currentPiece.color);\n        }\n      }\n    }\n    ctx.globalAlpha = 1.0;\n  }\n}\n\nfunction drawHeldPiece() {\n  if (!heldPiece) return;\n  \n  ctx.save();\n  ctx.fillStyle = '#fff';\n  ctx.font = '14px Arial';\n  ctx.fillText('HOLD', 10, 20);\n  \n  const offsetX = 10;\n  const offsetY = 30;\n  const miniSize = 15;\n  \n  for (let row = 0; row < heldPiece.shape.length; row++) {\n    for (let col = 0; col < heldPiece.shape[row].length; col++) {\n      if (heldPiece.shape[row][col]) {\n        ctx.fillStyle = heldPiece.color;\n        ctx.fillRect(\n          offsetX + col * miniSize,\n          offsetY + row * miniSize,\n          miniSize - 1,\n          miniSize - 1\n        );\n      }\n    }\n  }\n  ctx.restore();\n}\n\nfunction draw() {\n  drawBoard();\n  drawPiece();\n  drawHeldPiece();\n}\n\n// Game Loop\nfunction update(time = 0) {\n  if (!gameRunning) return;\n  \n  const deltaTime = time - lastTime;\n  lastTime = time;\n  dropCounter += deltaTime;\n  \n  // Auto drop (moves UP in reverse tetris)\n  if (dropCounter > dropInterval) {\n    if (!move(0, -1)) {\n      mergePiece();\n      clearLines();\n      spawnPiece();\n    }\n    dropCounter = 0;\n  }\n  \n  // Handle continuous movement\n  if (keys['ArrowLeft'] || keys['Left']) {\n    if (time - lastMoveTime > moveDelay) {\n      move(-1, 0);\n      lastMoveTime = time;\n    }\n  }\n  if (keys['ArrowRight'] || keys['Right']) {\n    if (time - lastMoveTime > moveDelay) {\n      move(1, 0);\n      lastMoveTime = time;\n    }\n  }\n  if (keys['ArrowDown'] || keys['Down']) {\n    if (time - lastMoveTime > 50) {\n      if (move(0, -1)) {\n        score += 1;\n        document.getElementById('score').textContent = score;\n      }\n      lastMoveTime = time;\n    }\n  }\n  \n  draw();\n  requestAnimationFrame(update);\n}\n\n// Game Over\nfunction gameOver() {\n  gameRunning = false;\n  document.getElementById('finalScore').textContent = score;\n  document.getElementById('finalLines').textContent = lines;\n  document.getElementById('gameOver').style.display = 'block';\n}\n\n// Restart Game\nfunction restartGame() {\n  initBoard();\n  score = 0;\n  lines = 0;\n  level = 1;\n  dropInterval = 1000;\n  dropCounter = 0;\n  heldPiece = null;\n  canHold = true;\n  gameRunning = true;\n  \n  document.getElementById('score').textContent = score;\n  document.getElementById('lines').textContent = lines;\n  document.getElementById('level').textContent = level;\n  document.getElementById('gameOver').style.display = 'none';\n  \n  spawnPiece();\n  lastTime = performance.now();\n  requestAnimationFrame(update);\n}\n\n// Input Handlers\ndocument.addEventListener('keydown', (e) => {\n  if (!gameRunning) return;\n  \n  keys[e.key] = true;\n  \n  if (e.key === 'ArrowUp' || e.key === 'z' || e.key === 'Z') {\n    const rotated = rotate(currentPiece);\n    if (!collision(rotated, currentX, currentY)) {\n      currentPiece = rotated;\n    }\n    e.preventDefault();\n  }\n  \n  if (e.key === ' ') {\n    hardDrop();\n    e.preventDefault();\n  }\n  \n  if (e.key === 'c' || e.key === 'C') {\n    holdPiece();\n    e.preventDefault();\n  }\n});\n\ndocument.addEventListener('keyup', (e) => {\n  keys[e.key] = false;\n});\n\n// Mobile Controls\nfunction setupMobileControls() {\n  const addTouchHandler = (id, handler) => {\n    const elem = document.getElementById(id);\n    if (!elem) return;\n    \n    elem.addEventListener('touchstart', (e) => {\n      e.preventDefault();\n      handler();\n    });\n    \n    elem.addEventListener('click', (e) => {\n      e.preventDefault();\n      handler();\n    });\n  };\n  \n  addTouchHandler('dpadLeft', () => {\n    if (gameRunning) move(-1, 0);\n  });\n  \n  addTouchHandler('dpadRight', () => {\n    if (gameRunning) move(1, 0);\n  });\n  \n  addTouchHandler('dpadDown', () => {\n    if (gameRunning && move(0, -1)) {\n      score += 1;\n      document.getElementById('score').textContent = score;\n    }\n  });\n  \n  addTouchHandler('dpadUp', () => {\n    if (gameRunning) {\n      const rotated = rotate(currentPiece);\n      if (!collision(rotated, currentX, currentY)) {\n        currentPiece = rotated;\n      }\n    }\n  });\n  \n  addTouchHandler('btnA', () => {\n    if (gameRunning) hardDrop();\n  });\n  \n  addTouchHandler('btnB', () => {\n    if (gameRunning) {\n      const rotated = rotate(currentPiece);\n      if (!collision(rotated, currentX, currentY)) {\n        currentPiece = rotated;\n      }\n    }\n  });\n  \n  addTouchHandler('btnC', () => {\n    if (gameRunning) holdPiece();\n  });\n}\n\n// Restart Button\ndocument.getElementById('restartBtn').addEventListener('click', restartGame);\n\n// Initialize and Start Game\ninitBoard();\nspawnPiece();\nsetupMobileControls();\nlastTime = performance.now();\nrequestAnimationFrame(update);\n</script>\n\n</body>\n</html>"
}
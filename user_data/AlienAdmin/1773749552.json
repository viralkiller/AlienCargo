    "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Sideways Tetris</title>\n<style>\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nbody {\n  width: 100vw;\n  height: 100vh;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);\n  font-family: 'Arial', sans-serif;\n  overflow: hidden;\n}\n\n#game-container {\n  position: relative;\n  width: 1280px;\n  height: 720px;\n  background: #000;\n  box-shadow: 0 0 40px rgba(0,0,0,0.8);\n}\n\ncanvas {\n  display: block;\n  background: #0a0a0a;\n}\n\n#game-over {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  background: rgba(0,0,0,0.95);\n  padding: 40px;\n  border-radius: 20px;\n  text-align: center;\n  display: none;\n  z-index: 100;\n  border: 3px solid #fff;\n}\n\n#game-over h1 {\n  color: #ff3333;\n  font-size: 48px;\n  margin-bottom: 20px;\n  text-shadow: 2px 2px 4px rgba(0,0,0,0.8);\n}\n\n#game-over p {\n  color: #fff;\n  font-size: 24px;\n  margin-bottom: 30px;\n}\n\n#restart-btn {\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n  color: white;\n  border: none;\n  padding: 15px 40px;\n  font-size: 24px;\n  border-radius: 10px;\n  cursor: pointer;\n  transition: transform 0.2s;\n}\n\n#restart-btn:hover {\n  transform: scale(1.1);\n}\n\n#mobile-controls {\n  display: none;\n  position: absolute;\n  bottom: 0;\n  left: 0;\n  width: 100%;\n  height: 40%;\n  grid-template-columns: repeat(3, 1fr);\n  grid-template-rows: repeat(2, 1fr);\n  gap: 10px;\n  padding: 10px;\n  background: rgba(0,0,0,0.3);\n}\n\n.control-btn {\n  background: rgba(255,255,255,0.2);\n  border: 2px solid rgba(255,255,255,0.5);\n  border-radius: 10px;\n  color: white;\n  font-size: 24px;\n  font-weight: bold;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  cursor: pointer;\n  user-select: none;\n  transition: background 0.1s;\n  touch-action: manipulation;\n}\n\n.control-btn:active {\n  background: rgba(255,255,255,0.5);\n}\n\n#dpad {\n  grid-column: 1;\n  grid-row: 1 / 3;\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  grid-template-rows: repeat(3, 1fr);\n  gap: 5px;\n}\n\n.dpad-btn {\n  background: rgba(255,255,255,0.2);\n  border: 2px solid rgba(255,255,255,0.5);\n  border-radius: 8px;\n  color: white;\n  font-size: 20px;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  cursor: pointer;\n  user-select: none;\n  touch-action: manipulation;\n}\n\n.dpad-btn:active {\n  background: rgba(255,255,255,0.5);\n}\n\n#up-btn { grid-column: 2; grid-row: 1; }\n#left-btn { grid-column: 1; grid-row: 2; }\n#down-btn { grid-column: 2; grid-row: 2; }\n#right-btn { grid-column: 3; grid-row: 2; }\n\n#action-buttons {\n  grid-column: 3;\n  grid-row: 1 / 3;\n  display: flex;\n  flex-direction: column;\n  gap: 10px;\n  justify-content: center;\n  align-items: center;\n}\n\n.action-btn {\n  width: 80%;\n  height: 30%;\n  background: rgba(255,100,100,0.3);\n  border: 2px solid rgba(255,100,100,0.7);\n  border-radius: 50%;\n  color: white;\n  font-size: 24px;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  cursor: pointer;\n  user-select: none;\n  touch-action: manipulation;\n}\n\n.action-btn:active {\n  background: rgba(255,100,100,0.6);\n}\n\n@media (max-width: 1280px) or (max-height: 720px) {\n  #game-container {\n    width: 100vw;\n    height: 60vh;\n  }\n  canvas {\n    width: 100% !important;\n    height: 100% !important;\n  }\n  #mobile-controls {\n    display: grid;\n  }\n}\n\n#score-display {\n  position: absolute;\n  top: 20px;\n  left: 20px;\n  color: white;\n  font-size: 24px;\n  font-weight: bold;\n  text-shadow: 2px 2px 4px rgba(0,0,0,0.8);\n  z-index: 10;\n}\n\n#level-display {\n  position: absolute;\n  top: 60px;\n  left: 20px;\n  color: white;\n  font-size: 20px;\n  font-weight: bold;\n  text-shadow: 2px 2px 4px rgba(0,0,0,0.8);\n  z-index: 10;\n}\n</style>\n</head>\n<body>\n<div id=\"game-container\">\n  <canvas id=\"gameCanvas\" width=\"1280\" height=\"720\"></canvas>\n  <div id=\"score-display\">Score: 0</div>\n  <div id=\"level-display\">Level: 1</div>\n  <div id=\"game-over\">\n    <h1>GAME OVER</h1>\n    <p>Final Score: <span id=\"final-score\">0</span></p>\n    <p>Level: <span id=\"final-level\">1</span></p>\n    <button id=\"restart-btn\">PLAY AGAIN</button>\n  </div>\n  <div id=\"mobile-controls\">\n    <div id=\"dpad\">\n      <div class=\"dpad-btn\" id=\"up-btn\">\u25b2</div>\n      <div class=\"dpad-btn\" id=\"left-btn\">\u25c4</div>\n      <div class=\"dpad-btn\" id=\"down-btn\">\u25bc</div>\n      <div class=\"dpad-btn\" id=\"right-btn\">\u25ba</div>\n    </div>\n    <div style=\"grid-column: 2; grid-row: 1 / 3;\"></div>\n    <div id=\"action-buttons\">\n      <div class=\"action-btn\" id=\"a-btn\">A</div>\n      <div class=\"action-btn\" id=\"b-btn\">B</div>\n      <div class=\"action-btn\" id=\"c-btn\">C</div>\n    </div>\n  </div>\n</div>\n\n<script>\nconst canvas = document.getElementById('gameCanvas');\nconst ctx = canvas.getContext('2d');\nconst gameOverDiv = document.getElementById('game-over');\nconst restartBtn = document.getElementById('restart-btn');\nconst scoreDisplay = document.getElementById('score-display');\nconst levelDisplay = document.getElementById('level-display');\nconst finalScoreSpan = document.getElementById('final-score');\nconst finalLevelSpan = document.getElementById('final-level');\n\n// Game Constants\nconst COLS = 20; // Horizontal (pieces fall from left)\nconst ROWS = 12; // Vertical\nconst BLOCK_SIZE = 36;\nconst GAME_WIDTH = COLS * BLOCK_SIZE;\nconst GAME_HEIGHT = ROWS * BLOCK_SIZE;\nconst OFFSET_X = (canvas.width - GAME_WIDTH) / 2;\nconst OFFSET_Y = (canvas.height - GAME_HEIGHT) / 2;\n\n// Tetromino shapes (standard Tetris pieces)\nconst SHAPES = {\n  I: [[1,1,1,1]],\n  O: [[1,1],[1,1]],\n  T: [[0,1,0],[1,1,1]],\n  S: [[0,1,1],[1,1,0]],\n  Z: [[1,1,0],[0,1,1]],\n  J: [[1,0,0],[1,1,1]],\n  L: [[0,0,1],[1,1,1]]\n};\n\nconst COLORS = {\n  I: '#00f0f0',\n  O: '#f0f000',\n  T: '#a000f0',\n  S: '#00f000',\n  Z: '#f00000',\n  J: '#0000f0',\n  L: '#f0a000'\n};\n\n// Game State\nlet game = {\n  board: [],\n  currentPiece: null,\n  nextPiece: null,\n  score: 0,\n  level: 1,\n  linesCleared: 0,\n  gameOver: false,\n  fallSpeed: 500,\n  lastFallTime: 0,\n  fastFall: false\n};\n\nlet keys = {};\n\n// Initialize game\nfunction init() {\n  game.board = Array(ROWS).fill().map(() => Array(COLS).fill(0));\n  game.score = 0;\n  game.level = 1;\n  game.linesCleared = 0;\n  game.gameOver = false;\n  game.fallSpeed = 500;\n  game.lastFallTime = Date.now();\n  game.fastFall = false;\n  \n  game.currentPiece = createPiece();\n  game.nextPiece = createPiece();\n  \n  gameOverDiv.style.display = 'none';\n  updateDisplay();\n  \n  gameLoop();\n}\n\nfunction createPiece() {\n  const shapeKeys = Object.keys(SHAPES);\n  const type = shapeKeys[Math.floor(Math.random() * shapeKeys.length)];\n  return {\n    type: type,\n    shape: JSON.parse(JSON.stringify(SHAPES[type])),\n    x: 0, // Start from left edge\n    y: Math.floor(ROWS / 2) - 1,\n    color: COLORS[type]\n  };\n}\n\nfunction rotatePiece(piece) {\n  const newShape = piece.shape[0].map((_, i) =>\n    piece.shape.map(row => row[i]).reverse()\n  );\n  return newShape;\n}\n\nfunction collision(piece, offsetX = 0, offsetY = 0, shape = piece.shape) {\n  for (let row = 0; row < shape.length; row++) {\n    for (let col = 0; col < shape[row].length; col++) {\n      if (shape[row][col]) {\n        const newX = piece.x + col + offsetX;\n        const newY = piece.y + row + offsetY;\n        \n        if (newX < 0 || newX >= COLS || newY < 0 || newY >= ROWS) {\n          return true;\n        }\n        \n        if (game.board[newY] && game.board[newY][newX]) {\n          return true;\n        }\n      }\n    }\n  }\n  return false;\n}\n\nfunction mergePiece() {\n  for (let row = 0; row < game.currentPiece.shape.length; row++) {\n    for (let col = 0; col < game.currentPiece.shape[row].length; col++) {\n      if (game.currentPiece.shape[row][col]) {\n        const boardY = game.currentPiece.y + row;\n        const boardX = game.currentPiece.x + col;\n        if (boardY >= 0 && boardY < ROWS && boardX >= 0 && boardX < COLS) {\n          game.board[boardY][boardX] = game.currentPiece.color;\n        }\n      }\n    }\n  }\n}\n\nfunction clearLines() {\n  let linesCleared = 0;\n  \n  // In sideways Tetris, we clear columns instead of rows\n  for (let col = 0; col < COLS; col++) {\n    let isFull = true;\n    for (let row = 0; row < ROWS; row++) {\n      if (!game.board[row][col]) {\n        isFull = false;\n        break;\n      }\n    }\n    \n    if (isFull) {\n      linesCleared++;\n      // Remove the column and shift everything right\n      for (let c = col; c > 0; c--) {\n        for (let r = 0; r < ROWS; r++) {\n          game.board[r][c] = game.board[r][c - 1];\n        }\n      }\n      // Fill leftmost column with zeros\n      for (let r = 0; r < ROWS; r++) {\n        game.board[r][0] = 0;\n      }\n    }\n  }\n  \n  if (linesCleared > 0) {\n    game.linesCleared += linesCleared;\n    game.score += linesCleared * 100 * game.level;\n    game.level = Math.floor(game.linesCleared / 10) + 1;\n    game.fallSpeed = Math.max(100, 500 - (game.level - 1) * 50);\n    updateDisplay();\n  }\n}\n\nfunction spawnNewPiece() {\n  game.currentPiece = game.nextPiece;\n  game.nextPiece = createPiece();\n  \n  if (collision(game.currentPiece)) {\n    endGame();\n  }\n}\n\nfunction endGame() {\n  game.gameOver = true;\n  finalScoreSpan.textContent = game.score;\n  finalLevelSpan.textContent = game.level;\n  gameOverDiv.style.display = 'block';\n}\n\nfunction updateDisplay() {\n  scoreDisplay.textContent = 'Score: ' + game.score;\n  levelDisplay.textContent = 'Level: ' + game.level;\n}\n\n// Input handling\ndocument.addEventListener('keydown', (e) => {\n  if (game.gameOver) return;\n  keys[e.key] = true;\n  \n  if (e.key === 'ArrowUp' || e.key === 'w') {\n    // Move up\n    if (!collision(game.currentPiece, 0, -1)) {\n      game.currentPiece.y--;\n    }\n  } else if (e.key === 'ArrowDown' || e.key === 's') {\n    // Move down\n    if (!collision(game.currentPiece, 0, 1)) {\n      game.currentPiece.y++;\n    }\n  } else if (e.key === 'ArrowLeft' || e.key === 'a') {\n    // Move left (backward)\n    if (!collision(game.currentPiece, -1, 0)) {\n      game.currentPiece.x--;\n    }\n  } else if (e.key === 'ArrowRight' || e.key === 'd') {\n    // Move right (forward - fast fall)\n    game.fastFall = true;\n  } else if (e.key === 'z' || e.key === 'Z') {\n    // A button - rotate counterclockwise\n    const newShape = rotatePiece(game.currentPiece);\n    if (!collision(game.currentPiece, 0, 0, newShape)) {\n      game.currentPiece.shape = newShape;\n    }\n  } else if (e.key === 'x' || e.key === 'X') {\n    // B button - rotate clockwise\n    let newShape = rotatePiece(game.currentPiece);\n    newShape = rotatePiece({shape: newShape}).shape;\n    newShape = rotatePiece({shape: newShape}).shape;\n    if (!collision(game.currentPiece, 0, 0, newShape)) {\n      game.currentPiece.shape = newShape;\n    }\n  } else if (e.key === 'c' || e.key === 'C') {\n    // C button - hard drop\n    while (!collision(game.currentPiece, 1, 0)) {\n      game.currentPiece.x++;\n    }\n    mergePiece();\n    clearLines();\n    spawnNewPiece();\n    game.lastFallTime = Date.now();\n  }\n});\n\ndocument.addEventListener('keyup', (e) => {\n  keys[e.key] = false;\n  if (e.key === 'ArrowRight' || e.key === 'd') {\n    game.fastFall = false;\n  }\n});\n\n// Mobile controls\nfunction setupMobileControls() {\n  document.getElementById('up-btn').addEventListener('touchstart', (e) => {\n    e.preventDefault();\n    if (!game.gameOver && !collision(game.currentPiece, 0, -1)) {\n      game.currentPiece.y--;\n    }\n  });\n  \n  document.getElementById('down-btn').addEventListener('touchstart', (e) => {\n    e.preventDefault();\n    if (!game.gameOver && !collision(game.currentPiece, 0, 1)) {\n      game.currentPiece.y++;\n    }\n  });\n  \n  document.getElementById('left-btn').addEventListener('touchstart', (e) => {\n    e.preventDefault();\n    if (!game.gameOver && !collision(game.currentPiece, -1, 0)) {\n      game.currentPiece.x--;\n    }\n  });\n  \n  document.getElementById('right-btn').addEventListener('touchstart', (e) => {\n    e.preventDefault();\n    game.fastFall = true;\n  });\n  \n  document.getElementById('right-btn').addEventListener('touchend', (e) => {\n    e.preventDefault();\n    game.fastFall = false;\n  });\n  \n  document.getElementById('a-btn').addEventListener('touchstart', (e) => {\n    e.preventDefault();\n    if (!game.gameOver) {\n      const newShape = rotatePiece(game.currentPiece);\n      if (!collision(game.currentPiece, 0, 0, newShape)) {\n        game.currentPiece.shape = newShape;\n      }\n    }\n  });\n  \n  document.getElementById('b-btn').addEventListener('touchstart', (e) => {\n    e.preventDefault();\n    if (!game.gameOver) {\n      let newShape = rotatePiece(game.currentPiece);\n      newShape = rotatePiece({shape: newShape}).shape;\n      newShape = rotatePiece({shape: newShape}).shape;\n      if (!collision(game.currentPiece, 0, 0, newShape)) {\n        game.currentPiece.shape = newShape;\n      }\n    }\n  });\n  \n  document.getElementById('c-btn').addEventListener('touchstart', (e) => {\n    e.preventDefault();\n    if (!game.gameOver) {\n      while (!collision(game.currentPiece, 1, 0)) {\n        game.currentPiece.x++;\n      }\n      mergePiece();\n      clearLines();\n      spawnNewPiece();\n      game.lastFallTime = Date.now();\n    }\n  });\n}\n\nsetupMobileControls();\n\nrestartBtn.addEventListener('click', () => {\n  init();\n});\n\n// Drawing functions\nfunction drawBlock(x, y, color) {\n  const pixelX = OFFSET_X + x * BLOCK_SIZE;\n  const pixelY = OFFSET_Y + y * BLOCK_SIZE;\n  \n  ctx.fillStyle = color;\n  ctx.fillRect(pixelX, pixelY, BLOCK_SIZE, BLOCK_SIZE);\n  \n  // Inner highlight\n  ctx.fillStyle = 'rgba(255,255,255,0.3)';\n  ctx.fillRect(pixelX + 2, pixelY + 2, BLOCK_SIZE - 4, BLOCK_SIZE - 4);\n  \n  // Border\n  ctx.strokeStyle = 'rgba(0,0,0,0.5)';\n  ctx.lineWidth = 2;\n  ctx.strokeRect(pixelX, pixelY, BLOCK_SIZE, BLOCK_SIZE);\n}\n\nfunction drawBoard() {\n  for (let row = 0; row < ROWS; row++) {\n    for (let col = 0; col < COLS; col++) {\n      if (game.board[row][col]) {\n        drawBlock(col, row, game.board[row][col]);\n      }\n    }\n  }\n}\n\nfunction drawPiece(piece) {\n  for (let row = 0; row < piece.shape.length; row++) {\n    for (let col = 0; col < piece.shape[row].length; col++) {\n      if (piece.shape[row][col]) {\n        drawBlock(piece.x + col, piece.y + row, piece.color);\n      }\n    }\n  }\n}\n\nfunction drawGrid() {\n  ctx.strokeStyle = 'rgba(255,255,255,0.1)';\n  ctx.lineWidth = 1;\n  \n  for (let col = 0; col <= COLS; col++) {\n    ctx.beginPath();\n    ctx.moveTo(OFFSET_X + col * BLOCK_SIZE, OFFSET_Y);\n    ctx.lineTo(OFFSET_X + col * BLOCK_SIZE, OFFSET_Y + GAME_HEIGHT);\n    ctx.stroke();\n  }\n  \n  for (let row = 0; row <= ROWS; row++) {\n    ctx.beginPath();\n    ctx.moveTo(OFFSET_X, OFFSET_Y + row * BLOCK_SIZE);\n    ctx.lineTo(OFFSET_X + GAME_WIDTH, OFFSET_Y + row * BLOCK_SIZE);\n    ctx.stroke();\n  }\n}\n\nfunction drawNextPiece() {\n  const nextX = OFFSET_X + GAME_WIDTH + 40;\n  const nextY = OFFSET_Y + 100;\n  \n  ctx.fillStyle = 'white';\n  ctx.font = '24px Arial';\n  ctx.fillText('NEXT', nextX, nextY - 20);\n  \n  for (let row = 0; row < game.nextPiece.shape.length; row++) {\n    for (let col = 0; col < game.nextPiece.shape[row].length; col++) {\n      if (game.nextPiece.shape[row][col]) {\n        const pixelX = nextX + col * 30;\n        const pixelY = nextY + row * 30;\n        ctx.fillStyle = game.nextPiece.color;\n        ctx.fillRect(pixelX, pixelY, 28, 28);\n      }\n    }\n  }\n}\n\nfunction draw() {\n  ctx.fillStyle = '#0a0a0a';\n  ctx.fillRect(0, 0, canvas.width, canvas.height);\n  \n  drawGrid();\n  drawBoard();\n  drawPiece(game.currentPiece);\n  drawNextPiece();\n}\n\n// Game loop\nfunction gameLoop() {\n  if (game.gameOver) return;\n  \n  const currentTime = Date.now();\n  const fallSpeed = game.fastFall ? 50 : game.fallSpeed;\n  \n  if (currentTime - game.lastFallTime > fallSpeed) {\n    if (!collision(game.currentPiece, 1, 0)) {\n      game.currentPiece.x++;\n    } else {\n      mergePiece();\n      clearLines();\n      spawnNewPiece();\n    }\n    game.lastFallTime = currentTime;\n  }\n  \n  draw();\n  requestAnimationFrame(gameLoop);\n}\n\n// Start the game immediately\ninit();\n</script>\n</body>\n</html>"

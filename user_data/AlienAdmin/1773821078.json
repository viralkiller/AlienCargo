{
    "timestamp": 1773821078,
    "class": "Racing game",
    "prompt": "Outrun style racing game but set in a volcano environment",
    "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Volcano Racer - Outrun Style</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        body {\n            margin: 0;\n            padding: 0;\n            background: linear-gradient(180deg, #2a0a0a 0%, #0a0000 100%);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            min-height: 100vh;\n            width: 100vw;\n            color: white;\n            font-family: 'Courier New', monospace;\n            overflow: hidden;\n        }\n        #game-container {\n            position: relative;\n            width: 1280px;\n            height: 720px;\n            max-width: 100vw;\n            max-height: 100vh;\n            box-shadow: 0 0 40px rgba(255, 100, 0, 0.6);\n        }\n        @media (max-width: 1280px) or (max-height: 720px) {\n            #game-container {\n                width: 100vw;\n                height: 100vh;\n            }\n        }\n        #mobile-controls {\n            display: none;\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            width: 100%;\n            height: 40%;\n            z-index: 1000;\n            pointer-events: none;\n        }\n        .control-section {\n            position: absolute;\n            pointer-events: all;\n        }\n        .dpad-container {\n            bottom: 20px;\n            left: 20px;\n            width: 180px;\n            height: 180px;\n        }\n        .dpad-btn {\n            position: absolute;\n            width: 60px;\n            height: 60px;\n            background: rgba(255, 80, 0, 0.4);\n            border: 2px solid rgba(255, 150, 50, 0.8);\n            border-radius: 8px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 24px;\n            color: #fff;\n            user-select: none;\n            touch-action: none;\n        }\n        .dpad-btn:active {\n            background: rgba(255, 120, 0, 0.8);\n        }\n        #btn-up { top: 0; left: 60px; }\n        #btn-down { bottom: 0; left: 60px; }\n        #btn-left { top: 60px; left: 0; }\n        #btn-right { top: 60px; right: 0; }\n        .action-container {\n            bottom: 20px;\n            right: 20px;\n            width: 200px;\n            height: 180px;\n        }\n        .action-btn {\n            position: absolute;\n            width: 70px;\n            height: 70px;\n            background: rgba(255, 50, 0, 0.5);\n            border: 3px solid rgba(255, 100, 0, 0.9);\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 20px;\n            font-weight: bold;\n            color: #fff;\n            user-select: none;\n            touch-action: none;\n        }\n        .action-btn:active {\n            background: rgba(255, 100, 0, 0.9);\n            transform: scale(0.95);\n        }\n        #btn-a { bottom: 0; left: 0; }\n        #btn-b { bottom: 40px; left: 65px; }\n        #btn-c { bottom: 80px; left: 130px; }\n        @media (orientation: portrait) {\n            body::before {\n                content: \"\u27f2 ROTATE TO PLAY\";\n                position: fixed;\n                top: 50%;\n                left: 50%;\n                transform: translate(-50%, -50%);\n                font-size: 32px;\n                color: #ff6600;\n                text-align: center;\n                z-index: 10000;\n            }\n        }\n        @media (orientation: landscape) and (max-width: 1024px) {\n            #mobile-controls {\n                display: block;\n            }\n        }\n    </style>\n    <script src=\"https://cdn.jsdelivr.net/npm/phaser@3.55.2/dist/phaser.min.js\"></script>\n</head>\n<body>\n\n<div id=\"game-container\"></div>\n\n<div id=\"mobile-controls\">\n    <div class=\"control-section dpad-container\">\n        <div class=\"dpad-btn\" id=\"btn-up\">\u25b2</div>\n        <div class=\"dpad-btn\" id=\"btn-down\">\u25bc</div>\n        <div class=\"dpad-btn\" id=\"btn-left\">\u25c4</div>\n        <div class=\"dpad-btn\" id=\"btn-right\">\u25ba</div>\n    </div>\n    <div class=\"control-section action-container\">\n        <div class=\"action-btn\" id=\"btn-a\">A</div>\n        <div class=\"action-btn\" id=\"btn-b\">B</div>\n        <div class=\"action-btn\" id=\"btn-c\">C</div>\n    </div>\n</div>\n\n<script>\n    console.log(\"[SYSTEM] Initializing Volcano Racer...\");\n\n    // Game Constants\n    const GAME_WIDTH = 1280;\n    const GAME_HEIGHT = 720;\n    const SEGMENT_LENGTH = 200;\n    const RUMBLE_LENGTH = 3;\n    const ROAD_WIDTH = 2000;\n    const CAMERA_HEIGHT = 1000;\n    const CAMERA_DEPTH = 1 / Math.tan((100 / 2) * Math.PI / 180);\n    const DRAW_DISTANCE = 300;\n\n    // Volcano-themed colors\n    const COLORS = {\n        LIGHT: { \n            road: 0x3a3a3a, \n            grass: 0x1a0a00, \n            rumble: 0xff4400, \n            lane: 0xffaa00 \n        },\n        DARK: { \n            road: 0x2a2a2a, \n            grass: 0x0f0500, \n            rumble: 0xcc0000, \n            lane: 0xff6600 \n        },\n        SKY: 0x4a1010,\n        LAVA: 0xff3300\n    };\n\n    class VolcanoRacerScene extends Phaser.Scene {\n        constructor() {\n            super('VolcanoRacerScene');\n            this.segments = [];\n            this.cameraZ = 0;\n            this.playerX = 0;\n            this.speed = 0;\n            this.maxSpeed = SEGMENT_LENGTH * 60;\n            this.accel = this.maxSpeed / 50;\n            this.breaking = -this.maxSpeed;\n            this.decel = -this.maxSpeed / 50;\n            this.offRoadDecel = -this.maxSpeed / 2;\n            this.offRoadLimit = this.maxSpeed / 4;\n            this.centrifugal = 0.3;\n            this.trackLength = 0;\n            this.graphics = null;\n            this.keys = {};\n            this.gameTime = 60;\n            this.gameOver = false;\n            this.checkpoints = [];\n            this.nextCheckpoint = 0;\n            this.trafficCars = [];\n            this.lavaParticles = [];\n            this.mobileControls = {\n                up: false,\n                down: false,\n                left: false,\n                right: false,\n                a: false,\n                b: false,\n                c: false\n            };\n        }\n\n        preload() {\n            console.log(\"[SYSTEM] Preloading assets...\");\n            this.createCarTexture('playerCar', 0xff3300);\n            this.createCarTexture('trafficCar1', 0x660000);\n            this.createCarTexture('trafficCar2', 0x440000);\n            console.log(\"[SYSTEM] Assets preloaded.\");\n        }\n\n        createCarTexture(key, color) {\n            let graphics = this.make.graphics({x: 0, y: 0, add: false});\n            graphics.fillStyle(color, 1);\n            graphics.fillRect(0, 20, 80, 40);\n            graphics.fillStyle(0x000000, 1);\n            graphics.fillRect(10, 60, 15, 20);\n            graphics.fillRect(55, 60, 15, 20);\n            graphics.fillStyle(0xffaa00, 1);\n            graphics.fillRect(15, 0, 50, 20);\n            graphics.fillStyle(0xff0000, 1);\n            graphics.fillCircle(10, 30, 3);\n            graphics.fillCircle(70, 30, 3);\n            graphics.generateTexture(key, 80, 80);\n        }\n\n        create() {\n            console.log(\"[SCENE] VolcanoRacerScene initialized.\");\n            \n            // Background gradient\n            this.backgroundGraphics = this.add.graphics();\n            this.drawVolcanoBackground();\n\n            // Road rendering graphics\n            this.graphics = this.add.graphics();\n\n            // Generate track\n            this.resetRoad();\n\n            // UI\n            this.createUI();\n\n            // Keyboard input\n            this.keys = this.input.keyboard.createCursorKeys();\n            this.setupInputLogging();\n\n            // Mobile controls\n            this.setupMobileControls();\n\n            // Player sprite\n            this.playerSprite = this.add.sprite(GAME_WIDTH / 2, GAME_HEIGHT - 100, 'playerCar');\n            this.playerSprite.setOrigin(0.5, 1);\n            this.playerSprite.setScale(1.5);\n            this.playerSprite.setDepth(1000);\n\n            // Timer\n            this.time.addEvent({\n                delay: 1000,\n                callback: this.updateTimer,\n                callbackScope: this,\n                loop: true\n            });\n\n            // Spawn traffic\n            this.spawnTraffic();\n\n            console.log(\"[GAME] Auto-starting game loop...\");\n        }\n\n        drawVolcanoBackground() {\n            this.backgroundGraphics.clear();\n            // Sky gradient\n            for (let y = 0; y < GAME_HEIGHT * 0.5; y++) {\n                let color = Phaser.Display.Color.Interpolate.ColorWithColor(\n                    Phaser.Display.Color.ValueToColor(0x2a0505),\n                    Phaser.Display.Color.ValueToColor(0x4a1010),\n                    GAME_HEIGHT * 0.5,\n                    y\n                );\n                this.backgroundGraphics.fillStyle(Phaser.Display.Color.GetColor(color.r, color.g, color.b), 1);\n                this.backgroundGraphics.fillRect(0, y, GAME_WIDTH, 1);\n            }\n\n            // Volcano silhouette\n            this.backgroundGraphics.fillStyle(0x0a0000, 1);\n            this.backgroundGraphics.beginPath();\n            this.backgroundGraphics.moveTo(0, GAME_HEIGHT * 0.5);\n            this.backgroundGraphics.lineTo(GAME_WIDTH * 0.3, GAME_HEIGHT * 0.3);\n            this.backgroundGraphics.lineTo(GAME_WIDTH * 0.4, GAME_HEIGHT * 0.15);\n            this.backgroundGraphics.lineTo(GAME_WIDTH * 0.6, GAME_HEIGHT * 0.15);\n            this.backgroundGraphics.lineTo(GAME_WIDTH * 0.7, GAME_HEIGHT * 0.3);\n            this.backgroundGraphics.lineTo(GAME_WIDTH, GAME_HEIGHT * 0.5);\n            this.backgroundGraphics.closePath();\n            this.backgroundGraphics.fillPath();\n\n            // Lava glow at peak\n            this.backgroundGraphics.fillStyle(0xff3300, 0.3);\n            this.backgroundGraphics.fillCircle(GAME_WIDTH * 0.5, GAME_HEIGHT * 0.15, 40);\n        }\n\n        createUI() {\n            // Speed indicator\n            this.speedText = this.add.text(30, 30, 'SPEED: 0 km/h', {\n                fontFamily: 'Courier New',\n                fontSize: '28px',\n                color: '#ff6600',\n                backgroundColor: '#000000',\n                padding: { x: 15, y: 10 }\n            }).setDepth(2000);\n\n            // Timer\n            this.timerText = this.add.text(GAME_WIDTH - 30, 30, 'TIME: 60', {\n                fontFamily: 'Courier New',\n                fontSize: '28px',\n                color: '#ffaa00',\n                backgroundColor: '#000000',\n                padding: { x: 15, y: 10 }\n            }).setOrigin(1, 0).setDepth(2000);\n\n            // Distance to checkpoint\n            this.checkpointText = this.add.text(GAME_WIDTH / 2, 30, 'CHECKPOINT: 0m', {\n                fontFamily: 'Courier New',\n                fontSize: '24px',\n                color: '#ffffff',\n                backgroundColor: '#660000',\n                padding: { x: 12, y: 8 }\n            }).setOrigin(0.5, 0).setDepth(2000);\n\n            // Restart button (hidden initially)\n            this.restartBtn = this.add.text(GAME_WIDTH / 2, GAME_HEIGHT / 2 + 100, '[ RESTART ]', {\n                fontFamily: 'Courier New',\n                fontSize: '36px',\n                color: '#ffaa00',\n                backgroundColor: '#330000',\n                padding: { x: 20, y: 15 }\n            }).setOrigin(0.5).setDepth(3000).setInteractive({ useHandCursor: true }).setVisible(false);\n\n            this.restartBtn.on('pointerdown', () => {\n                console.log(\"[UI EVENT] Restart button clicked.\");\n                this.scene.restart();\n            });\n\n            this.restartBtn.on('pointerover', () => this.restartBtn.setStyle({ color: '#ffffff' }));\n            this.restartBtn.on('pointerout', () => this.restartBtn.setStyle({ color: '#ffaa00' }));\n\n            // Game Over text\n            this.gameOverText = this.add.text(GAME_WIDTH / 2, GAME_HEIGHT / 2, 'TIME UP!', {\n                fontFamily: 'Courier New',\n                fontSize: '72px',\n                color: '#ff0000',\n                stroke: '#000000',\n                strokeThickness: 6\n            }).setOrigin(0.5).setDepth(3000).setVisible(false);\n        }\n\n        setupInputLogging() {\n            this.input.keyboard.on('keydown-UP', () => console.log(\"[INPUT] UP pressed (Accelerate)\"));\n            this.input.keyboard.on('keydown-DOWN', () => console.log(\"[INPUT] DOWN pressed (Brake)\"));\n            this.input.keyboard.on('keydown-LEFT', () => console.log(\"[INPUT] LEFT pressed\"));\n            this.input.keyboard.on('keydown-RIGHT', () => console.log(\"[INPUT] RIGHT pressed\"));\n        }\n\n        setupMobileControls() {\n            const setupButton = (id, key) => {\n                const btn = document.getElementById(id);\n                if (btn) {\n                    btn.addEventListener('touchstart', (e) => {\n                        e.preventDefault();\n                        this.mobileControls[key] = true;\n                        console.log(`[MOBILE INPUT] ${key.toUpperCase()} pressed`);\n                    });\n                    btn.addEventListener('touchend', (e) => {\n                        e.preventDefault();\n                        this.mobileControls[key] = false;\n                    });\n                }\n            };\n\n            setupButton('btn-up', 'up');\n            setupButton('btn-down', 'down');\n            setupButton('btn-left', 'left');\n            setupButton('btn-right', 'right');\n            setupButton('btn-a', 'a');\n            setupButton('btn-b', 'b');\n            setupButton('btn-c', 'c');\n        }\n\n        resetRoad() {\n            console.log(\"[GAME LOGIC] Generating volcano track...\");\n            this.segments = [];\n            this.checkpoints = [];\n            \n            for (let n = 0; n < 800; n++) {\n                let curve = 0;\n                if (n > 100 && n < 150) curve = 2.5;\n                else if (n > 200 && n < 250) curve = -3;\n                else if (n > 300 && n < 350) curve = 1.5;\n                else if (n > 400 && n < 480) curve = -2;\n                else if (n > 550 && n < 620) curve = 3.5;\n                else if (n > 700 && n < 750) curve = -2.5;\n\n                this.segments.push({\n                    index: n,\n                    p1: { world: { x: 0, y: 0, z: n * SEGMENT_LENGTH }, camera: {}, screen: {} },\n                    p2: { world: { x: 0, y: 0, z: (n + 1) * SEGMENT_LENGTH }, camera: {}, screen: {} },\n                    curve: curve,\n                    color: Math.floor(n / RUMBLE_LENGTH) % 2 ? COLORS.DARK : COLORS.LIGHT\n                });\n\n                // Add checkpoints every 200 segments\n                if (n > 0 && n % 200 === 0) {\n                    this.checkpoints.push(n * SEGMENT_LENGTH);\n                }\n            }\n\n            // Finish line\n            this.segments[this.segments.length - 1].color = { \n                road: 0xffffff, \n                grass: 0xff0000, \n                rumble: 0xffffff, \n                lane: 0x000000 \n            };\n\n            this.trackLength = this.segments.length * SEGMENT_LENGTH;\n            console.log(`[GAME LOGIC] Track generated: ${this.segments.length} segments, ${this.checkpoints.length} checkpoints.`);\n        }\n\n        spawnTraffic() {\n            for (let i = 0; i < 8; i++) {\n                let z = Math.random() * this.trackLength;\n                let sprite = this.add.sprite(0, 0, i % 2 === 0 ? 'trafficCar1' : 'trafficCar2');\n                sprite.setOrigin(0.5, 1);\n                sprite.setVisible(false);\n                \n                this.trafficCars.push({\n                    sprite: sprite,\n                    offset: (Math.random() - 0.5) * 1.8,\n                    z: z,\n                    speed: this.maxSpeed * (0.4 + Math.random() * 0.2)\n                });\n            }\n            console.log(`[GAME LOGIC] Spawned ${this.trafficCars.length} traffic cars.`);\n        }\n\n        updateTimer() {\n            if (this.gameOver) return;\n            \n            this.gameTime--;\n            this.timerText.setText(`TIME: ${this.gameTime}`);\n\n            if (this.gameTime <= 0) {\n                this.triggerGameOver();\n            }\n        }\n\n        triggerGameOver() {\n            console.log(\"[GAME] Game Over triggered.\");\n            this.gameOver = true;\n            this.speed = 0;\n            this.gameOverText.setVisible(true);\n            this.restartBtn.setVisible(true);\n        }\n\n        update(time, delta) {\n            if (this.gameOver) return;\n\n            let dt = delta / 1000;\n            let playerSegment = this.findSegment(this.cameraZ + CAMERA_HEIGHT);\n            let speedPercent = this.speed / this.maxSpeed;\n            let dx = dt * 2 * speedPercent;\n\n            // Input handling (keyboard + mobile)\n            let leftPressed = this.keys.left.isDown || this.mobileControls.left;\n            let rightPressed = this.keys.right.isDown || this.mobileControls.right;\n            let upPressed = this.keys.up.isDown || this.mobileControls.up || this.mobileControls.a;\n            let downPressed = this.keys.down.isDown || this.mobileControls.down || this.mobileControls.b;\n\n            if (leftPressed) {\n                this.playerX -= dx;\n            } else if (rightPressed) {\n                this.playerX += dx;\n            }\n\n            // Centrifugal force\n            this.playerX -= (dx * speedPercent * playerSegment.curve * this.centrifugal);\n\n            if (upPressed) {\n                this.speed = Phaser.Math.Clamp(this.speed + this.accel * dt, 0, this.maxSpeed);\n            } else if (downPressed) {\n                this.speed = Phaser.Math.Clamp(this.speed + this.breaking * dt, 0, this.maxSpeed);\n            } else {\n                this.speed = Phaser.Math.Clamp(this.speed + this.decel * dt, 0, this.maxSpeed);\n            }\n\n            // Off-road penalty\n            if ((this.playerX < -1 || this.playerX > 1) && this.speed > this.offRoadLimit) {\n                this.speed = Phaser.Math.Clamp(this.speed + this.offRoadDecel * dt, 0, this.maxSpeed);\n            }\n\n            this.playerX = Phaser.Math.Clamp(this.playerX, -2, 2);\n            this.cameraZ = (this.cameraZ + (this.speed * dt)) % this.trackLength;\n\n            // Check for checkpoint\n            if (this.nextCheckpoint < this.checkpoints.length) {\n                let cpDist = this.checkpoints[this.nextCheckpoint] - this.cameraZ;\n                if (cpDist < 0) cpDist += this.trackLength;\n                \n                this.checkpointText.setText(`CHECKPOINT: ${Math.floor(cpDist / 100)}m`);\n\n                if (cpDist < SEGMENT_LENGTH * 2) {\n                    console.log(`[GAME] Checkpoint ${this.nextCheckpoint + 1} reached! +15 seconds`);\n                    this.gameTime += 15;\n                    this.nextCheckpoint++;\n                    \n                    // Flash effect\n                    this.checkpointText.setStyle({ color: '#00ff00' });\n                    this.time.delayedCall(500, () => {\n                        this.checkpointText.setStyle({ color: '#ffffff' });\n                    });\n                }\n            }\n\n            // Update traffic\n            this.updateTraffic(dt);\n\n            // Update HUD\n            this.speedText.setText(`SPEED: ${Math.floor(this.speed / 100)} km/h`);\n\n            // Render\n            this.renderTrack();\n        }\n\n        updateTraffic(dt) {\n            for (let car of this.trafficCars) {\n                car.z = (car.z - car.speed * dt);\n                if (car.z < 0) car.z += this.trackLength;\n\n                let segment = this.findSegment(car.z);\n                let relativeZ = car.z - this.cameraZ;\n                if (relativeZ < 0) relativeZ += this.trackLength;\n\n                if (relativeZ < SEGMENT_LENGTH * DRAW_DISTANCE && relativeZ > 0) {\n                    this.project(\n                        segment.p1,\n                        (this.playerX * ROAD_WIDTH),\n                        CAMERA_HEIGHT,\n                        this.cameraZ,\n                        CAMERA_DEPTH, GAME_WIDTH, GAME_HEIGHT, ROAD_WIDTH\n                    );\n\n                    let scale = segment.p1.screen.scale;\n                    let x = segment.p1.screen.x + (car.offset * segment.p1.screen.w);\n                    let y = segment.p1.screen.y;\n\n                    car.sprite.setPosition(x, y);\n                    car.sprite.setScale(scale * 1.2);\n                    car.sprite.setVisible(true);\n                    car.sprite.setDepth(100000 - relativeZ);\n\n                    // Collision detection\n                    if (relativeZ < SEGMENT_LENGTH * 3) {\n                        let playerOffset = this.playerX;\n                        if (Math.abs(playerOffset - car.offset) < 0.3) {\n                            console.log(\"[COLLISION] Hit traffic car!\");\n                            this.speed = this.speed * 0.3;\n                            this.playerX += (car.offset > playerOffset ? -0.3 : 0.3);\n                        }\n                    }\n                } else {\n                    car.sprite.setVisible(false);\n                }\n            }\n        }\n\n        findSegment(z) {\n            return this.segments[Math.floor(z / SEGMENT_LENGTH) % this.segments.length];\n        }\n\n        project(p, cameraX, cameraY, cameraZ, cameraDepth, width, height, roadWidth) {\n            p.camera.x = (p.world.x || 0) - cameraX;\n            p.camera.y = (p.world.y || 0) - cameraY;\n            p.camera.z = (p.world.z || 0) - cameraZ;\n            p.screen.scale = cameraDepth / p.camera.z;\n            p.screen.x = Math.round((width / 2) + (p.screen.scale * p.camera.x * width / 2));\n            p.screen.y = Math.round((height / 2) - (p.screen.scale * p.camera.y * height / 2));\n            p.screen.w = Math.round((p.screen.scale * roadWidth * width / 2));\n        }\n\n        renderTrack() {\n            this.graphics.clear();\n\n            let baseSegment = this.findSegment(this.cameraZ);\n            let maxy = GAME_HEIGHT;\n            let x = 0;\n            let dx = -(baseSegment.curve * (this.cameraZ % SEGMENT_LENGTH) / SEGMENT_LENGTH);\n\n            for (let n = 0; n < DRAW_DISTANCE; n++) {\n                let segment = this.segments[(baseSegment.index + n) % this.segments.length];\n                segment.looped = segment.index < baseSegment.index;\n\n                this.project(\n                    segment.p1,\n                    (this.playerX * ROAD_WIDTH) - x,\n                    CAMERA_HEIGHT,\n                    this.cameraZ - (segment.looped ? this.trackLength : 0),\n                    CAMERA_DEPTH, GAME_WIDTH, GAME_HEIGHT, ROAD_WIDTH\n                );\n\n                this.project(\n                    segment.p2,\n                    (this.playerX * ROAD_WIDTH) - x - dx,\n                    CAMERA_HEIGHT,\n                    this.cameraZ - (segment.looped ? this.trackLength : 0),\n                    CAMERA_DEPTH, GAME_WIDTH, GAME_HEIGHT, ROAD_WIDTH\n                );\n\n                x = x + dx;\n                dx = dx + segment.curve;\n\n                if ((segment.p1.camera.z <= CAMERA_DEPTH) || (segment.p2.screen.y >= maxy)) {\n                    continue;\n                }\n\n                this.drawSegment(\n                    GAME_WIDTH,\n                    segment.p1.screen.x, segment.p1.screen.y, segment.p1.screen.w,\n                    segment.p2.screen.x, segment.p2.screen.y, segment.p2.screen.w,\n                    segment.color\n                );\n\n                maxy = segment.p2.screen.y;\n            }\n        }\n\n        drawSegment(width, x1, y1, w1, x2, y2, w2, color) {\n            let r1 = w1 / 6;\n            let r2 = w2 / 6;\n\n            // Grass\n            this.graphics.fillStyle(color.grass, 1);\n            this.graphics.fillRect(0, y2, width, y1 - y2);\n\n            // Rumble strips (volcano glow effect)\n            this.drawPolygon(x1 - w1 - r1, y1, x1 - w1, y1, x2 - w2, y2, x2 - w2 - r2, y2, color.rumble);\n            this.drawPolygon(x1 + w1 + r1, y1, x1 + w1, y1, x2 + w2, y2, x2 + w2 + r2, y2, color.rumble);\n\n            // Road\n            this.drawPolygon(x1 - w1, y1, x1 + w1, y1, x2 + w2, y2, x2 - w2, y2, color.road);\n\n            // Lane markings\n            if (color.lane) {\n                let lanew1 = w1 * 0.02;\n                let lanew2 = w2 * 0.02;\n                this.drawPolygon(x1 - lanew1/2, y1, x1 + lanew1/2, y1, x2 + lanew2/2, y2, x2 - lanew2/2, y2, color.lane);\n            }\n        }\n\n        drawPolygon(x1, y1, x2, y2, x3, y3, x4, y4, color) {\n            this.graphics.fillStyle(color, 1);\n            this.graphics.beginPath();\n            this.graphics.moveTo(x1, y1);\n            this.graphics.lineTo(x2, y2);\n            this.graphics.lineTo(x3, y3);\n            this.graphics.lineTo(x4, y4);\n            this.graphics.closePath();\n            this.graphics.fillPath();\n        }\n    }\n\n    const config = {\n        type: Phaser.AUTO,\n        width: GAME_WIDTH,\n        height: GAME_HEIGHT,\n        parent: 'game-container',\n        scene: [VolcanoRacerScene],\n        physics: {\n            default: 'arcade',\n            arcade: { debug: false }\n        },\n        scale: {\n            mode: Phaser.Scale.FIT,\n            autoCenter: Phaser.Scale.CENTER_BOTH\n        }\n    };\n\n    console.log(\"[SYSTEM] Booting Volcano Racer...\");\n    const game = new Phaser.Game(config);\n    console.log(\"[SYSTEM] Game initialization complete. Auto-starting...\");\n\n</script>\n</body>\n</html>"
}
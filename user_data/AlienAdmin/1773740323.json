    "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>OutRun Racing</title>\n<style>\n* {\n    margin: 0;\n    padding: 0;\n    box-sizing: border-box;\n    overscroll-behavior: none;\n}\n\nbody {\n    overflow: hidden;\n    background: #000;\n    font-family: 'Courier New', monospace;\n    touch-action: none;\n}\n\n#gameCanvas {\n    display: block;\n    background: #72D7EE;\n    image-rendering: pixelated;\n    image-rendering: crisp-edges;\n}\n\n#ui {\n    position: absolute;\n    top: 10px;\n    left: 10px;\n    color: #fff;\n    font-size: 20px;\n    text-shadow: 2px 2px 4px #000;\n    pointer-events: none;\n    z-index: 10;\n}\n\n#gameOver {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    background: rgba(0, 0, 0, 0.9);\n    padding: 40px;\n    border: 4px solid #ff0000;\n    color: #fff;\n    text-align: center;\n    display: none;\n    z-index: 100;\n}\n\n#gameOver h1 {\n    font-size: 48px;\n    margin-bottom: 20px;\n    color: #ff0000;\n}\n\n#gameOver p {\n    font-size: 24px;\n    margin-bottom: 30px;\n}\n\n#restartBtn {\n    font-size: 24px;\n    padding: 15px 40px;\n    background: #ff0000;\n    color: #fff;\n    border: none;\n    cursor: pointer;\n    font-family: 'Courier New', monospace;\n    font-weight: bold;\n}\n\n#restartBtn:hover {\n    background: #cc0000;\n}\n\n/* Mobile Controls */\n#mobileControls {\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    width: 100%;\n    height: 40%;\n    display: none;\n    z-index: 50;\n}\n\n@media (max-width: 768px), (pointer: coarse) {\n    #mobileControls {\n        display: grid;\n        grid-template-columns: 1fr 1fr 1fr;\n        grid-template-rows: 1fr 1fr;\n        gap: 10px;\n        padding: 10px;\n    }\n}\n\n.control-section {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n}\n\n#dpad {\n    grid-column: 1;\n    grid-row: 2;\n    position: relative;\n    width: 150px;\n    height: 150px;\n}\n\n.dpad-btn {\n    position: absolute;\n    width: 50px;\n    height: 50px;\n    background: rgba(255, 255, 255, 0.3);\n    border: 2px solid rgba(255, 255, 255, 0.5);\n    border-radius: 5px;\n    touch-action: none;\n}\n\n#dpad-up {\n    top: 0;\n    left: 50px;\n}\n\n#dpad-down {\n    bottom: 0;\n    left: 50px;\n}\n\n#dpad-left {\n    top: 50px;\n    left: 0;\n}\n\n#dpad-right {\n    top: 50px;\n    right: 0;\n}\n\n#actionBtns {\n    grid-column: 3;\n    grid-row: 2;\n    position: relative;\n    width: 150px;\n    height: 150px;\n}\n\n.action-btn {\n    position: absolute;\n    width: 60px;\n    height: 60px;\n    background: rgba(255, 0, 0, 0.4);\n    border: 3px solid rgba(255, 255, 255, 0.6);\n    border-radius: 50%;\n    color: #fff;\n    font-size: 20px;\n    font-weight: bold;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    touch-action: none;\n}\n\n#btnA {\n    bottom: 0;\n    left: 0;\n}\n\n#btnB {\n    bottom: 30px;\n    left: 45px;\n}\n\n#btnC {\n    bottom: 60px;\n    left: 90px;\n}\n</style>\n</head>\n<body>\n\n<canvas id=\"gameCanvas\"></canvas>\n\n<div id=\"ui\">\n    <div>TIME: <span id=\"timeDisplay\">60</span></div>\n    <div>SPEED: <span id=\"speedDisplay\">0</span> km/h</div>\n    <div>DISTANCE: <span id=\"distanceDisplay\">0</span> m</div>\n</div>\n\n<div id=\"gameOver\">\n    <h1>GAME OVER</h1>\n    <p>DISTANCE: <span id=\"finalDistance\">0</span> m</p>\n    <button id=\"restartBtn\">RESTART</button>\n</div>\n\n<div id=\"mobileControls\">\n    <div class=\"control-section\" id=\"dpad\">\n        <div class=\"dpad-btn\" id=\"dpad-up\"></div>\n        <div class=\"dpad-btn\" id=\"dpad-down\"></div>\n        <div class=\"dpad-btn\" id=\"dpad-left\"></div>\n        <div class=\"dpad-btn\" id=\"dpad-right\"></div>\n    </div>\n    <div class=\"control-section\"></div>\n    <div class=\"control-section\"></div>\n    <div class=\"control-section\"></div>\n    <div class=\"control-section\"></div>\n    <div class=\"control-section\" id=\"actionBtns\">\n        <div class=\"action-btn\" id=\"btnA\">A</div>\n        <div class=\"action-btn\" id=\"btnB\">B</div>\n        <div class=\"action-btn\" id=\"btnC\">C</div>\n    </div>\n</div>\n\n<script>\nconst canvas = document.getElementById('gameCanvas');\nconst ctx = canvas.getContext('2d');\n\n// Set canvas size\nfunction resizeCanvas() {\n    canvas.width = window.innerWidth;\n    canvas.height = window.innerHeight;\n}\nresizeCanvas();\nwindow.addEventListener('resize', resizeCanvas);\n\n// Game constants\nconst ROAD_WIDTH = 2000;\nconst SEGMENT_LENGTH = 200;\nconst CAMERA_DEPTH = 0.84;\nconst DRAW_DISTANCE = 300;\nconst PLAYER_X_CENTER = 0;\n\n// Colors\nconst COLORS = {\n    SKY: ['#72D7EE', '#FF6B9D', '#FFD700'],\n    GROUND: ['#10A020', '#0F8F1F'],\n    ROAD: ['#808080', '#707070'],\n    LANE: '#fff',\n    RUMBLE: ['#fff', '#ff0000']\n};\n\n// Game state\nlet gameState = {\n    running: true,\n    position: 0,\n    playerX: 0,\n    speed: 0,\n    time: 60,\n    maxSpeed: 300,\n    acceleration: 0.3,\n    deceleration: 0.15,\n    brake: 0.5,\n    centrifugal: 0.3,\n    steer: 0,\n    skyIndex: 0\n};\n\n// Input handling\nconst keys = {};\nconst touch = {\n    left: false,\n    right: false,\n    up: false,\n    down: false,\n    a: false\n};\n\nwindow.addEventListener('keydown', (e) => {\n    keys[e.key] = true;\n});\n\nwindow.addEventListener('keyup', (e) => {\n    keys[e.key] = false;\n});\n\n// Mobile controls\nfunction setupMobileControls() {\n    const buttons = {\n        'dpad-left': () => { touch.left = true; },\n        'dpad-right': () => { touch.right = true; },\n        'dpad-up': () => { touch.up = true; },\n        'dpad-down': () => { touch.down = true; },\n        'btnA': () => { touch.a = true; }\n    };\n\n    for (let id in buttons) {\n        const btn = document.getElementById(id);\n        if (btn) {\n            btn.addEventListener('touchstart', (e) => {\n                e.preventDefault();\n                buttons[id]();\n            });\n            btn.addEventListener('touchend', (e) => {\n                e.preventDefault();\n                if (id.includes('dpad-left')) touch.left = false;\n                if (id.includes('dpad-right')) touch.right = false;\n                if (id.includes('dpad-up')) touch.up = false;\n                if (id.includes('dpad-down')) touch.down = false;\n                if (id === 'btnA') touch.a = false;\n            });\n        }\n    }\n}\n\nsetupMobileControls();\n\n// Track segments\nconst segments = [];\n\nfunction createSegment(curve, y) {\n    return {\n        index: segments.length,\n        curve: curve,\n        y: y,\n        z: segments.length * SEGMENT_LENGTH,\n        cars: []\n    };\n}\n\nfunction buildTrack() {\n    let y = 0;\n    \n    // Straight section\n    for (let i = 0; i < 20; i++) {\n        segments.push(createSegment(0, y));\n    }\n    \n    // Right curve\n    for (let i = 0; i < 30; i++) {\n        segments.push(createSegment(3, y));\n    }\n    \n    // Straight\n    for (let i = 0; i < 15; i++) {\n        segments.push(createSegment(0, y));\n    }\n    \n    // Left curve\n    for (let i = 0; i < 30; i++) {\n        segments.push(createSegment(-3, y));\n    }\n    \n    // Hill up\n    for (let i = 0; i < 20; i++) {\n        y += 50;\n        segments.push(createSegment(0, y));\n    }\n    \n    // Hill down\n    for (let i = 0; i < 20; i++) {\n        y -= 50;\n        segments.push(createSegment(0, y));\n    }\n    \n    // S-curve\n    for (let i = 0; i < 20; i++) {\n        segments.push(createSegment(2, y));\n    }\n    for (let i = 0; i < 20; i++) {\n        segments.push(createSegment(-2, y));\n    }\n    \n    // Checkpoint fork\n    for (let i = 0; i < 10; i++) {\n        segments.push(createSegment(0, y));\n        if (i === 5) {\n            segments[segments.length - 1].checkpoint = true;\n        }\n    }\n    \n    // Right path\n    for (let i = 0; i < 25; i++) {\n        segments.push(createSegment(4, y));\n    }\n    \n    // Straight\n    for (let i = 0; i < 20; i++) {\n        segments.push(createSegment(0, y));\n    }\n    \n    // Left curve\n    for (let i = 0; i < 30; i++) {\n        segments.push(createSegment(-3, y));\n    }\n    \n    // Another checkpoint\n    for (let i = 0; i < 10; i++) {\n        segments.push(createSegment(0, y));\n        if (i === 5) {\n            segments[segments.length - 1].checkpoint = true;\n        }\n    }\n    \n    // Final section\n    for (let i = 0; i < 50; i++) {\n        segments.push(createSegment(Math.sin(i * 0.3) * 2, y));\n    }\n}\n\nbuildTrack();\n\n// Traffic cars\nconst trafficCars = [];\n\nfunction spawnTrafficCar() {\n    const segment = Math.floor(Math.random() * segments.length);\n    const x = (Math.random() - 0.5) * 1.5;\n    const speed = 80 + Math.random() * 60;\n    \n    trafficCars.push({\n        segment: segment,\n        x: x,\n        speed: speed,\n        z: segments[segment].z\n    });\n}\n\n// Spawn initial traffic\nfor (let i = 0; i < 15; i++) {\n    spawnTrafficCar();\n}\n\n// Projection helpers\nfunction project(p, cameraX, cameraY, cameraZ) {\n    const camDist = cameraZ - p.z;\n    if (camDist <= 0) return null;\n    \n    const scale = CAMERA_DEPTH / camDist;\n    const x = (1 + scale * (p.x - cameraX)) * canvas.width / 2;\n    const y = (1 - scale * (p.y - cameraY)) * canvas.height / 2;\n    const w = scale * ROAD_WIDTH * canvas.width / 2;\n    \n    return { x, y, w, scale };\n}\n\nfunction findSegment(z) {\n    return segments[Math.floor(z / SEGMENT_LENGTH) % segments.length];\n}\n\n// Drawing functions\nfunction drawSegment(seg, prevSeg, cameraX, cameraY, cameraZ) {\n    const p1 = project({ x: 0, y: seg.y, z: seg.z }, cameraX, cameraY, cameraZ);\n    const p2 = project({ x: 0, y: prevSeg.y, z: prevSeg.z }, cameraX, cameraY, cameraZ);\n    \n    if (!p1 || !p2) return;\n    \n    // Road colors\n    const roadColor = COLORS.ROAD[Math.floor(seg.index / 3) % 2];\n    const grassColor = COLORS.GROUND[Math.floor(seg.index / 3) % 2];\n    const rumbleColor = COLORS.RUMBLE[Math.floor(seg.index / 3) % 2];\n    \n    // Draw grass\n    ctx.fillStyle = grassColor;\n    ctx.fillRect(0, p2.y, canvas.width, p1.y - p2.y);\n    \n    // Draw rumble strips\n    const rumbleWidth = p1.w * 0.15;\n    ctx.fillStyle = rumbleColor;\n    ctx.fillRect(p1.x - p1.w - rumbleWidth, p2.y, rumbleWidth, p1.y - p2.y);\n    ctx.fillRect(p1.x + p1.w, p2.y, rumbleWidth, p1.y - p2.y);\n    \n    // Draw road\n    ctx.fillStyle = roadColor;\n    ctx.beginPath();\n    ctx.moveTo(p1.x - p1.w, p1.y);\n    ctx.lineTo(p2.x - p2.w, p2.y);\n    ctx.lineTo(p2.x + p2.w, p2.y);\n    ctx.lineTo(p1.x + p1.w, p1.y);\n    ctx.closePath();\n    ctx.fill();\n    \n    // Draw lane markers\n    if (Math.floor(seg.index / 3) % 2 === 0) {\n        ctx.fillStyle = COLORS.LANE;\n        const laneW = p1.w / 40;\n        ctx.fillRect(p1.x - laneW / 2, p1.y, laneW, p2.y - p1.y);\n    }\n}\n\nfunction drawCar(car, seg, cameraX, cameraY, cameraZ) {\n    const carSeg = findSegment(car.z);\n    const p = project({ x: car.x, y: carSeg.y, z: car.z }, cameraX, cameraY, cameraZ);\n    \n    if (!p || p.scale <= 0) return;\n    \n    const carWidth = p.w * 0.4 * p.scale;\n    const carHeight = carWidth * 0.8;\n    \n    // Car body\n    ctx.fillStyle = '#ff0000';\n    ctx.fillRect(p.x - carWidth / 2, p.y - carHeight, carWidth, carHeight);\n    \n    // Car windows\n    ctx.fillStyle = '#333';\n    ctx.fillRect(p.x - carWidth * 0.35, p.y - carHeight * 0.8, carWidth * 0.7, carHeight * 0.4);\n}\n\nfunction drawPlayerCar() {\n    const carWidth = 100;\n    const carHeight = 80;\n    const carX = canvas.width / 2 + gameState.playerX * canvas.width / 2;\n    const carY = canvas.height - 150;\n    \n    // Shadow\n    ctx.fillStyle = 'rgba(0, 0, 0, 0.3)';\n    ctx.fillRect(carX - carWidth / 2 + 5, carY + carHeight - 5, carWidth, 10);\n    \n    // Car body\n    ctx.fillStyle = '#0066ff';\n    ctx.fillRect(carX - carWidth / 2, carY, carWidth, carHeight);\n    \n    // Windshield\n    ctx.fillStyle = '#88ccff';\n    ctx.fillRect(carX - carWidth * 0.35, carY + 10, carWidth * 0.7, carHeight * 0.3);\n    \n    // Wheels\n    ctx.fillStyle = '#000';\n    ctx.fillRect(carX - carWidth / 2 - 5, carY + 10, 10, 20);\n    ctx.fillRect(carX + carWidth / 2 - 5, carY + 10, 10, 20);\n    ctx.fillRect(carX - carWidth / 2 - 5, carY + carHeight - 30, 10, 20);\n    ctx.fillRect(carX + carWidth / 2 - 5, carY + carHeight - 30, 10, 20);\n}\n\n// Update game state\nfunction update(dt) {\n    if (!gameState.running) return;\n    \n    // Time countdown\n    gameState.time -= dt;\n    if (gameState.time <= 0) {\n        gameState.time = 0;\n        endGame();\n        return;\n    }\n    \n    // Input handling\n    const left = keys['ArrowLeft'] || touch.left;\n    const right = keys['ArrowRight'] || touch.right;\n    const accel = keys['ArrowUp'] || touch.up || touch.a;\n    const brake = keys['ArrowDown'] || touch.down;\n    \n    // Acceleration/Deceleration\n    if (accel) {\n        gameState.speed += gameState.acceleration;\n    } else if (brake) {\n        gameState.speed -= gameState.brake;\n    } else {\n        gameState.speed -= gameState.deceleration;\n    }\n    \n    gameState.speed = Math.max(0, Math.min(gameState.maxSpeed, gameState.speed));\n    \n    // Position update\n    gameState.position += gameState.speed * dt;\n    \n    // Get current segment\n    const baseSegment = findSegment(gameState.position);\n    \n    // Centrifugal force (curve pushes player)\n    const curve = baseSegment.curve;\n    gameState.playerX += curve * gameState.centrifugal * gameState.speed * dt * 0.001;\n    \n    // Steering\n    if (left) {\n        gameState.playerX -= dt * 2;\n    }\n    if (right) {\n        gameState.playerX += dt * 2;\n    }\n    \n    // Clamp player position (off-road slowdown)\n    if (Math.abs(gameState.playerX) > 1.2) {\n        gameState.speed *= 0.95;\n        gameState.playerX = Math.max(-1.5, Math.min(1.5, gameState.playerX));\n    }\n    \n    // Checkpoint detection\n    if (baseSegment.checkpoint && !baseSegment.passed) {\n        baseSegment.passed = true;\n        gameState.time = Math.min(60, gameState.time + 20);\n    }\n    \n    // Update traffic\n    trafficCars.forEach(car => {\n        car.z += car.speed * dt * 0.1;\n        \n        // Wrap traffic cars\n        if (car.z > gameState.position + 2000) {\n            car.z = gameState.position - 2000;\n        }\n        \n        // Collision detection\n        const carSeg = findSegment(car.z);\n        const dist = Math.abs(car.z - gameState.position);\n        const lateralDist = Math.abs(car.x - gameState.playerX);\n        \n        if (dist < 50 && lateralDist < 0.3) {\n            // Collision!\n            gameState.speed *= 0.4;\n            // Push player to the side\n            if (gameState.playerX < car.x) {\n                gameState.playerX -= 0.3;\n            } else {\n                gameState.playerX += 0.3;\n            }\n        }\n    });\n    \n    // Spawn more traffic occasionally\n    if (Math.random() < 0.01) {\n        spawnTrafficCar();\n    }\n}\n\n// Render\nfunction render() {\n    // Sky gradient\n    const skyGradient = ctx.createLinearGradient(0, 0, 0, canvas.height / 2);\n    skyGradient.addColorStop(0, COLORS.SKY[gameState.skyIndex]);\n    skyGradient.addColorStop(1, '#FFD700');\n    ctx.fillStyle = skyGradient;\n    ctx.fillRect(0, 0, canvas.width, canvas.height / 2);\n    \n    // Ground\n    ctx.fillStyle = COLORS.GROUND[0];\n    ctx.fillRect(0, canvas.height / 2, canvas.width, canvas.height / 2);\n    \n    const baseSegment = findSegment(gameState.position);\n    const baseIndex = baseSegment.index;\n    const cameraY = baseSegment.y + 1500;\n    const cameraX = gameState.playerX * ROAD_WIDTH;\n    const cameraZ = gameState.position;\n    \n    // Draw road segments\n    for (let n = 0; n < DRAW_DISTANCE; n++) {\n        const segIndex = (baseIndex + n) % segments.length;\n        const seg = segments[segIndex];\n        const prevSegIndex = segIndex === 0 ? segments.length - 1 : segIndex - 1;\n        const prevSeg = segments[prevSegIndex];\n        \n        if (seg.z > cameraZ - 500) {\n            drawSegment(seg, prevSeg, cameraX, cameraY, cameraZ);\n        }\n    }\n    \n    // Draw traffic cars\n    trafficCars.forEach(car => {\n        if (car.z > cameraZ && car.z < cameraZ + DRAW_DISTANCE * SEGMENT_LENGTH) {\n            drawCar(car, findSegment(car.z), cameraX, cameraY, cameraZ);\n        }\n    });\n    \n    // Draw player car\n    drawPlayerCar();\n    \n    // Update UI\n    document.getElementById('timeDisplay').textContent = Math.ceil(gameState.time);\n    document.getElementById('speedDisplay').textContent = Math.floor(gameState.speed);\n    document.getElementById('distanceDisplay').textContent = Math.floor(gameState.position / 10);\n}\n\n// Game loop\nlet lastTime = 0;\nfunction gameLoop(timestamp) {\n    const dt = Math.min((timestamp - lastTime) / 1000, 0.1);\n    lastTime = timestamp;\n    \n    update(dt);\n    render();\n    \n    requestAnimationFrame(gameLoop);\n}\n\n// End game\nfunction endGame() {\n    gameState.running = false;\n    document.getElementById('finalDistance').textContent = Math.floor(gameState.position / 10);\n    document.getElementById('gameOver').style.display = 'block';\n}\n\n// Restart\ndocument.getElementById('restartBtn').addEventListener('click', () => {\n    gameState = {\n        running: true,\n        position: 0,\n        playerX: 0,\n        speed: 0,\n        time: 60,\n        maxSpeed: 300,\n        acceleration: 0.3,\n        deceleration: 0.15,\n        brake: 0.5,\n        centrifugal: 0.3,\n        steer: 0,\n        skyIndex: Math.floor(Math.random() * 3)\n    };\n    \n    // Reset checkpoints\n    segments.forEach(seg => {\n        if (seg.checkpoint) seg.passed = false;\n    });\n    \n    // Reset traffic\n    trafficCars.length = 0;\n    for (let i = 0; i < 15; i++) {\n        spawnTrafficCar();\n    }\n    \n    document.getElementById('gameOver').style.display = 'none';\n});\n\n// Start the game immediately\ngameLoop(0);\n</script>\n\n</body>\n</html>"

    "prompt": "outrun style racing game",
    "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Outrun Racer</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        body {\n            overflow: hidden;\n            background: #000;\n            font-family: 'Courier New', monospace;\n        }\n        #gameCanvas {\n            display: block;\n            margin: 0 auto;\n            background: linear-gradient(to bottom, #FF1493 0%, #FF69B4 20%, #FFB6C1 40%, #87CEEB 60%, #1E90FF 100%);\n            image-rendering: pixelated;\n            image-rendering: crisp-edges;\n        }\n        #ui {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            pointer-events: none;\n        }\n        .hud {\n            color: #fff;\n            text-shadow: 3px 3px 0 #000;\n            font-size: 24px;\n            font-weight: bold;\n            padding: 20px;\n        }\n        #timer {\n            position: absolute;\n            top: 20px;\n            right: 20px;\n            font-size: 48px;\n            color: #FFD700;\n        }\n        #speed {\n            position: absolute;\n            top: 80px;\n            right: 20px;\n            font-size: 32px;\n        }\n        #message {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            font-size: 36px;\n            color: #FFD700;\n            text-align: center;\n            animation: pulse 1s infinite;\n        }\n        @keyframes pulse {\n            0%, 100% { opacity: 1; }\n            50% { opacity: 0.5; }\n        }\n    </style>\n</head>\n<body>\n    <canvas id=\"gameCanvas\"></canvas>\n    <div id=\"ui\">\n        <div id=\"timer\" class=\"hud\">60</div>\n        <div id=\"speed\" class=\"hud\">0 km/h</div>\n        <div id=\"message\" style=\"display:none;\"></div>\n    </div>\n\n    <script>\n        const canvas = document.getElementById('gameCanvas');\n        const ctx = canvas.getContext('2d');\n        \n        canvas.width = 800;\n        canvas.height = 600;\n\n        // Game constants\n        const ROAD_WIDTH = 2000;\n        const SEGMENT_LENGTH = 200;\n        const RUMBLE_LENGTH = 3;\n        const DRAW_DISTANCE = 300;\n        const CAMERA_HEIGHT = 1000;\n        const CAMERA_DEPTH = 1 / Math.tan((90 / 2) * Math.PI / 180);\n        const FOG_DENSITY = 5;\n        const MAX_SPEED = 280;\n        const ACCELERATION = 0.05;\n        const DECELERATION = 0.15;\n        const BREAKING = 0.3;\n        const CENTRIFUGAL_FORCE = 0.3;\n        const OFF_ROAD_DECEL = 0.5;\n        const COLLISION_SPEED_LOSS = 0.7;\n\n        // Colors\n        const COLORS = {\n            SKY: { dark: '#1E3A5F', light: '#87CEEB' },\n            GRASS: { dark: '#00AA00', light: '#00DD00' },\n            ROAD: { dark: '#555555', light: '#777777' },\n            RUMBLE: { dark: '#FF0000', light: '#FFFFFF' },\n            LANE: '#FFFFFF'\n        };\n\n        // Game state\n        let position = 0;\n        let speed = 0;\n        let playerX = 0;\n        let timer = 60;\n        let gameOver = false;\n        let checkpointsPassed = 0;\n        let lastTime = 0;\n\n        // Input\n        const keys = {};\n        document.addEventListener('keydown', e => keys[e.key] = true);\n        document.addEventListener('keyup', e => keys[e.key] = false);\n\n        // Track generation\n        const segments = [];\n        const trackLength = 150;\n\n        function createSegment(curve, y) {\n            return {\n                index: segments.length,\n                curve: curve,\n                y: y,\n                z: segments.length * SEGMENT_LENGTH,\n                sprites: []\n            };\n        }\n\n        function addRoad(enter, hold, leave, curve, y) {\n            const startY = segments.length > 0 ? segments[segments.length - 1].y : 0;\n            const endY = startY + y * SEGMENT_LENGTH;\n            const total = enter + hold + leave;\n            \n            for (let n = 0; n < enter; n++) {\n                const t = n / enter;\n                segments.push(createSegment(curve * t, startY + (endY - startY) * t));\n            }\n            for (let n = 0; n < hold; n++) {\n                segments.push(createSegment(curve, endY));\n            }\n            for (let n = 0; n < leave; n++) {\n                const t = n / leave;\n                segments.push(createSegment(curve * (1 - t), endY));\n            }\n        }\n\n        // Build track\n        addRoad(20, 30, 20, 0, 0);          // Straight start\n        addRoad(20, 40, 20, 4, 0);          // Right curve\n        addRoad(20, 30, 20, 0, 0);          // Straight\n        addRoad(20, 40, 20, -5, 5);         // Left curve uphill\n        addRoad(20, 30, 20, 0, 0);          // Straight\n        addRoad(20, 40, 20, -4, -5);        // Left curve downhill\n        addRoad(20, 30, 20, 0, 0);          // Straight\n        addRoad(20, 50, 20, 6, 0);          // Sharp right\n        addRoad(20, 30, 20, 0, 0);          // Straight\n        addRoad(20, 40, 20, -3, 3);         // Left curve uphill\n        addRoad(20, 30, 20, 0, 0);          // Straight\n\n        // Add checkpoints\n        const checkpointPositions = [50, 100, 150, 200, 250, 300, 350];\n        checkpointPositions.forEach(pos => {\n            if (pos < segments.length) {\n                segments[pos].checkpoint = true;\n            }\n        });\n\n        // Traffic cars\n        const traffic = [];\n        for (let i = 0; i < 15; i++) {\n            traffic.push({\n                z: Math.random() * segments.length * SEGMENT_LENGTH,\n                x: (Math.random() - 0.5) * 1.5,\n                speed: 100 + Math.random() * 50,\n                sprite: Math.random() > 0.5 ? 1 : 2\n            });\n        }\n\n        // Scenery sprites\n        for (let i = 0; i < segments.length; i += 5) {\n            if (Math.random() > 0.6) {\n                segments[i].sprites.push({\n                    x: (Math.random() > 0.5 ? 1 : -1) * (2 + Math.random() * 3),\n                    type: Math.floor(Math.random() * 3)\n                });\n            }\n        }\n\n        function findSegment(z) {\n            return segments[Math.floor(z / SEGMENT_LENGTH) % segments.length];\n        }\n\n        function project(p, cameraX, cameraY, cameraZ) {\n            const transX = p.x - cameraX;\n            const transY = p.y - cameraY;\n            const transZ = p.z - cameraZ;\n            \n            const scale = CAMERA_DEPTH / transZ;\n            const projX = canvas.width / 2 + scale * transX * canvas.width / 2;\n            const projY = canvas.height / 2 - scale * transY * canvas.height / 2;\n            const projW = scale * ROAD_WIDTH * canvas.width / 2;\n            \n            return { x: projX, y: projY, w: projW, scale: scale };\n        }\n\n        function drawSegment(segment, p1, p2, fog) {\n            const roadColor = Math.floor(segment.index / RUMBLE_LENGTH) % 2 ? COLORS.ROAD.dark : COLORS.ROAD.light;\n            const grassColor = Math.floor(segment.index / RUMBLE_LENGTH) % 2 ? COLORS.GRASS.dark : COLORS.GRASS.light;\n            const rumbleColor = Math.floor(segment.index / RUMBLE_LENGTH) % 2 ? COLORS.RUMBLE.dark : COLORS.RUMBLE.light;\n\n            // Grass\n            ctx.fillStyle = grassColor;\n            ctx.fillRect(0, p2.y, canvas.width, p1.y - p2.y);\n\n            // Road\n            ctx.fillStyle = roadColor;\n            drawTrapezoid(\n                p1.x - p1.w, p1.y,\n                p2.x - p2.w, p2.y,\n                p2.x + p2.w, p2.y,\n                p1.x + p1.w, p1.y\n            );\n\n            // Rumble strips\n            const rumbleW1 = p1.w / 15;\n            const rumbleW2 = p2.w / 15;\n            ctx.fillStyle = rumbleColor;\n            drawTrapezoid(\n                p1.x - p1.w - rumbleW1, p1.y,\n                p2.x - p2.w - rumbleW2, p2.y,\n                p2.x - p2.w, p2.y,\n                p1.x - p1.w, p1.y\n            );\n            drawTrapezoid(\n                p1.x + p1.w, p1.y,\n                p2.x + p2.w, p2.y,\n                p2.x + p2.w + rumbleW2, p2.y,\n                p1.x + p1.w + rumbleW1, p1.y\n            );\n\n            // Lane markers\n            if (Math.floor(segment.index / 5) % 2 === 0) {\n                ctx.fillStyle = COLORS.LANE;\n                const laneW1 = p1.w / 40;\n                const laneW2 = p2.w / 40;\n                drawTrapezoid(\n                    p1.x - laneW1, p1.y,\n                    p2.x - laneW2, p2.y,\n                    p2.x + laneW2, p2.y,\n                    p1.x + laneW1, p1.y\n                );\n            }\n\n            // Checkpoint marker\n            if (segment.checkpoint && !segment.passed) {\n                ctx.fillStyle = 'rgba(255, 215, 0, 0.5)';\n                drawTrapezoid(\n                    p1.x - p1.w * 1.2, p1.y,\n                    p2.x - p2.w * 1.2, p2.y,\n                    p2.x + p2.w * 1.2, p2.y,\n                    p1.x + p1.w * 1.2, p1.y\n                );\n            }\n\n            // Apply fog\n            if (fog > 0) {\n                ctx.fillStyle = `rgba(135, 206, 235, ${fog})`;\n                ctx.fillRect(0, p2.y, canvas.width, p1.y - p2.y);\n            }\n        }\n\n        function drawTrapezoid(x1, y1, x2, y2, x3, y3, x4, y4) {\n            ctx.beginPath();\n            ctx.moveTo(x1, y1);\n            ctx.lineTo(x2, y2);\n            ctx.lineTo(x3, y3);\n            ctx.lineTo(x4, y4);\n            ctx.closePath();\n            ctx.fill();\n        }\n\n        function drawSprite(sprite, p) {\n            const destW = p.w * 0.4;\n            const destH = destW * 1.5;\n            const destX = p.x - destW / 2;\n            const destY = p.y - destH;\n\n            ctx.fillStyle = sprite.color;\n            ctx.fillRect(destX, destY, destW, destH);\n        }\n\n        function drawCar(x, y, w, h, color) {\n            // Simple car representation\n            ctx.fillStyle = color;\n            ctx.fillRect(x - w/2, y - h, w, h);\n            ctx.fillStyle = '#222';\n            ctx.fillRect(x - w/2 + w*0.2, y - h*0.7, w*0.3, h*0.4);\n            ctx.fillRect(x + w*0.1, y - h*0.7, w*0.3, h*0.4);\n        }\n\n        function drawPlayerCar() {\n            const carW = 80;\n            const carH = 120;\n            const carX = canvas.width / 2 + (canvas.width / 2) * (playerX * 0.5);\n            const carY = canvas.height - 150;\n\n            // Shadow\n            ctx.fillStyle = 'rgba(0, 0, 0, 0.5)';\n            ctx.fillRect(carX - carW/2 + 5, carY - 10 + 5, carW, 20);\n\n            // Car body\n            drawCar(carX, carY, carW, carH, '#FF0000');\n            \n            // Spoiler\n            ctx.fillStyle = '#AA0000';\n            ctx.fillRect(carX - carW/2 - 5, carY - carH - 10, carW + 10, 15);\n        }\n\n        function update(dt) {\n            if (gameOver) return;\n\n            // Timer countdown\n            timer -= dt;\n            if (timer <= 0) {\n                timer = 0;\n                gameOver = true;\n                showMessage('TIME UP!');\n            }\n\n            const segment = findSegment(position);\n            const speedPercent = speed / MAX_SPEED;\n\n            // Input handling\n            if (keys['ArrowUp'] || keys['w']) {\n                speed += ACCELERATION * dt * 60;\n            } else if (keys['ArrowDown'] || keys['s']) {\n                speed -= BREAKING * dt * 60;\n            } else {\n                speed -= DECELERATION * dt * 60;\n            }\n\n            if (keys['ArrowLeft'] || keys['a']) {\n                playerX -= 0.02 * dt * 60 * (1 + speedPercent);\n            }\n            if (keys['ArrowRight'] || keys['d']) {\n                playerX += 0.02 * dt * 60 * (1 + speedPercent);\n            }\n\n            // Centrifugal force\n            playerX -= (segment.curve * speedPercent * CENTRIFUGAL_FORCE * dt * 60) / 1000;\n\n            // Speed limits\n            speed = Math.max(0, Math.min(MAX_SPEED, speed));\n\n            // Off-road penalty\n            if (Math.abs(playerX) > 1.0) {\n                speed -= OFF_ROAD_DECEL * dt * 60;\n                if (speed < 0) speed = 0;\n            }\n\n            // Keep player on track\n            playerX = Math.max(-2.5, Math.min(2.5, playerX));\n\n            // Move forward\n            position += speed * dt * 60;\n            \n            // Loop track\n            if (position >= segments.length * SEGMENT_LENGTH) {\n                position -= segments.length * SEGMENT_LENGTH;\n            }\n\n            // Check checkpoint\n            if (segment.checkpoint && !segment.passed) {\n                segment.passed = true;\n                timer += 15;\n                checkpointsPassed++;\n                showMessage('+15 SEC!', 1000);\n            }\n\n            // Update traffic\n            traffic.forEach(car => {\n                car.z += car.speed * dt * 60;\n                if (car.z > segments.length * SEGMENT_LENGTH) {\n                    car.z -= segments.length * SEGMENT_LENGTH;\n                }\n\n                // Collision detection\n                const carSegment = findSegment(car.z);\n                const relativeZ = car.z - position;\n                \n                if (relativeZ > -100 && relativeZ < 100) {\n                    const dx = playerX - car.x;\n                    if (Math.abs(dx) < 0.3) {\n                        speed *= COLLISION_SPEED_LOSS;\n                        playerX += dx > 0 ? 0.2 : -0.2;\n                    }\n                }\n            });\n\n            // Update UI\n            document.getElementById('timer').textContent = Math.ceil(timer);\n            document.getElementById('speed').textContent = Math.floor(speed) + ' km/h';\n        }\n\n        function render() {\n            // Clear sky\n            const gradient = ctx.createLinearGradient(0, 0, 0, canvas.height);\n            gradient.addColorStop(0, '#FF1493');\n            gradient.addColorStop(0.3, '#FF69B4');\n            gradient.addColorStop(0.5, '#FFB6C1');\n            gradient.addColorStop(0.7, '#87CEEB');\n            gradient.addColorStop(1, '#1E90FF');\n            ctx.fillStyle = gradient;\n            ctx.fillRect(0, 0, canvas.width, canvas.height);\n\n            // Draw sun\n            const sunGradient = ctx.createRadialGradient(canvas.width/2, canvas.height * 0.3, 10, canvas.width/2, canvas.height * 0.3, 100);\n            sunGradient.addColorStop(0, '#FFFF00');\n            sunGradient.addColorStop(0.5, '#FF6600');\n            sunGradient.addColorStop(1, 'rgba(255, 102, 0, 0)');\n            ctx.fillStyle = sunGradient;\n            ctx.fillRect(0, 0, canvas.width, canvas.height * 0.6);\n\n            const baseSegment = findSegment(position);\n            const baseIndex = baseSegment.index;\n            const cameraY = CAMERA_HEIGHT + baseSegment.y;\n            \n            let maxy = canvas.height;\n\n            // Draw road segments\n            for (let n = 0; n < DRAW_DISTANCE; n++) {\n                const segment = segments[(baseIndex + n) % segments.length];\n                const p1 = project({\n                    x: 0,\n                    y: segment.y + cameraY,\n                    z: segment.z - position + (n < DRAW_DISTANCE / 2 ? 0 : segments.length * SEGMENT_LENGTH)\n                }, playerX * ROAD_WIDTH, cameraY, position);\n\n                const nextSegment = segments[(baseIndex + n + 1) % segments.length];\n                const p2 = project({\n                    x: 0,\n                    y: nextSegment.y + cameraY,\n                    z: nextSegment.z - position + (n < DRAW_DISTANCE / 2 ? 0 : segments.length * SEGMENT_LENGTH)\n                }, playerX * ROAD_WIDTH, cameraY, position);\n\n                if (p1.scale <= 0 || p2.scale <= 0 || p1.y >= maxy) continue;\n\n                const fog = Math.pow(n / DRAW_DISTANCE, FOG_DENSITY);\n                drawSegment(segment, p1, p2, fog);\n\n                maxy = p1.y;\n\n                // Draw scenery\n                segment.sprites.forEach(sprite => {\n                    const spriteP = project({\n                        x: sprite.x * ROAD_WIDTH,\n                        y: segment.y + cameraY,\n                        z: segment.z - position + (n < DRAW_DISTANCE / 2 ? 0 : segments.length * SEGMENT_LENGTH)\n                    }, playerX * ROAD_WIDTH, cameraY, position);\n\n                    if (spriteP.scale > 0 && spriteP.y < maxy) {\n                        const colors = ['#228B22', '#8B4513', '#006400'];\n                        const shapes = ['triangle', 'rect', 'circle'];\n                        const shape = shapes[sprite.type];\n                        const color = colors[sprite.type];\n                        \n                        const size = spriteP.w * 0.3;\n                        ctx.fillStyle = color;\n                        \n                        if (shape === 'triangle') {\n                            ctx.beginPath();\n                            ctx.moveTo(spriteP.x, spriteP.y - size);\n                            ctx.lineTo(spriteP.x - size/2, spriteP.y);\n                            ctx.lineTo(spriteP.x + size/2, spriteP.y);\n                            ctx.closePath();\n                            ctx.fill();\n                        } else if (shape === 'rect') {\n                            ctx.fillRect(spriteP.x - size/3, spriteP.y - size, size/1.5, size);\n                        } else {\n                            ctx.beginPath();\n                            ctx.arc(spriteP.x, spriteP.y - size/2, size/2, 0, Math.PI * 2);\n                            ctx.fill();\n                        }\n                    }\n                });\n\n                // Draw traffic\n                traffic.forEach(car => {\n                    const carSegment = findSegment(car.z);\n                    if (carSegment.index === segment.index) {\n                        const carP = project({\n                            x: car.x * ROAD_WIDTH,\n                            y: segment.y + cameraY,\n                            z: car.z - position + (n < DRAW_DISTANCE / 2 ? 0 : segments.length * SEGMENT_LENGTH)\n                        }, playerX * ROAD_WIDTH, cameraY, position);\n\n                        if (carP.scale > 0.1 && carP.y < maxy) {\n                            const carW = carP.w * 0.25;\n                            const carH = carW * 1.5;\n                            const colors = ['#0000FF', '#FFFF00', '#00FF00', '#FF00FF'];\n                            drawCar(carP.x, carP.y, carW, carH, colors[car.sprite % colors.length]);\n                        }\n                    }\n                });\n            }\n\n            // Draw player car\n            drawPlayerCar();\n        }\n\n        function showMessage(text, duration = 2000) {\n            const msg = document.getElementById('message');\n            msg.textContent = text;\n            msg.style.display = 'block';\n            setTimeout(() => {\n                msg.style.display = 'none';\n            }, duration);\n        }\n\n        function gameLoop(timestamp) {\n            const dt = Math.min((timestamp - lastTime) / 1000, 0.1);\n            lastTime = timestamp;\n\n            if (dt > 0) {\n                update(dt);\n                render();\n            }\n\n            requestAnimationFrame(gameLoop);\n        }\n\n        // Initialize and start game\n        lastTime = performance.now();\n        requestAnimationFrame(gameLoop);\n    </script>\n</body>\n</html>"
}
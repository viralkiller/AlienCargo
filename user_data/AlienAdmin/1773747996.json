    "prompt": "tetris but with a goblin twist",
    "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Goblin Tetris</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            touch-action: manipulation;\n        }\n\n        body {\n            background: linear-gradient(135deg, #1a0f0a 0%, #2d1810 100%);\n            font-family: 'Courier New', monospace;\n            overflow: hidden;\n            width: 100vw;\n            height: 100vh;\n        }\n\n        #gameContainer {\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            width: 100%;\n            height: 100%;\n            position: relative;\n        }\n\n        #gameCanvas {\n            border: 4px solid #8b4513;\n            box-shadow: 0 0 30px rgba(255, 100, 0, 0.6);\n            background: #1a1a1a;\n            image-rendering: pixelated;\n        }\n\n        #scoreBoard {\n            position: absolute;\n            top: 20px;\n            left: 50%;\n            transform: translateX(-50%);\n            color: #ff6600;\n            font-size: 24px;\n            font-weight: bold;\n            text-shadow: 2px 2px 4px #000;\n            z-index: 100;\n        }\n\n        #gameOver {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            background: rgba(0, 0, 0, 0.9);\n            padding: 40px;\n            border: 4px solid #ff6600;\n            border-radius: 10px;\n            text-align: center;\n            display: none;\n            z-index: 200;\n        }\n\n        #gameOver h1 {\n            color: #ff0000;\n            font-size: 48px;\n            margin-bottom: 20px;\n            text-shadow: 3px 3px 6px #000;\n        }\n\n        #gameOver p {\n            color: #ff6600;\n            font-size: 24px;\n            margin-bottom: 30px;\n        }\n\n        #restartBtn {\n            background: #8b4513;\n            color: #fff;\n            border: 3px solid #ff6600;\n            padding: 15px 40px;\n            font-size: 24px;\n            font-weight: bold;\n            cursor: pointer;\n            border-radius: 5px;\n            transition: all 0.3s;\n        }\n\n        #restartBtn:hover {\n            background: #ff6600;\n            transform: scale(1.1);\n        }\n\n        /* Mobile gamepad */\n        #mobileControls {\n            display: none;\n            position: fixed;\n            bottom: 0;\n            left: 0;\n            width: 100%;\n            height: 40vh;\n            background: rgba(0, 0, 0, 0.5);\n            grid-template-rows: 1fr 1fr;\n            grid-template-columns: 1fr 1fr 1fr;\n            gap: 5px;\n            padding: 10px;\n            z-index: 150;\n        }\n\n        .control-btn {\n            background: rgba(139, 69, 19, 0.7);\n            border: 3px solid #ff6600;\n            border-radius: 10px;\n            color: #fff;\n            font-size: 24px;\n            font-weight: bold;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            user-select: none;\n            touch-action: none;\n        }\n\n        .control-btn:active {\n            background: rgba(255, 102, 0, 0.9);\n        }\n\n        #dpad {\n            grid-row: 2;\n            grid-column: 1;\n            display: grid;\n            grid-template-columns: 1fr 1fr 1fr;\n            grid-template-rows: 1fr 1fr 1fr;\n            gap: 5px;\n        }\n\n        #btnUp { grid-column: 2; grid-row: 1; }\n        #btnLeft { grid-column: 1; grid-row: 2; }\n        #btnRight { grid-column: 3; grid-row: 2; }\n        #btnDown { grid-column: 2; grid-row: 3; }\n\n        #actionBtns {\n            grid-row: 2;\n            grid-column: 3;\n            display: flex;\n            flex-direction: column;\n            justify-content: space-around;\n            align-items: flex-end;\n            padding: 10px;\n        }\n\n        .action-btn {\n            width: 70px;\n            height: 70px;\n            border-radius: 50%;\n            background: rgba(139, 69, 19, 0.7);\n            border: 3px solid #ff6600;\n            color: #fff;\n            font-size: 20px;\n            font-weight: bold;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .action-btn:active {\n            background: rgba(255, 102, 0, 0.9);\n        }\n\n        @media (max-width: 768px) {\n            #mobileControls {\n                display: grid;\n            }\n\n            #gameCanvas {\n                max-width: 90vw;\n                max-height: 50vh;\n            }\n\n            #scoreBoard {\n                font-size: 18px;\n                top: 10px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div id=\"gameContainer\">\n        <div id=\"scoreBoard\">\n            Score: <span id=\"score\">0</span> | Lines: <span id=\"lines\">0</span> | Goblins: <span id=\"goblins\">0</span>\n        </div>\n        <canvas id=\"gameCanvas\"></canvas>\n        \n        <div id=\"gameOver\">\n            <h1>GOBLIN DEFEATED!</h1>\n            <p>Final Score: <span id=\"finalScore\">0</span></p>\n            <button id=\"restartBtn\">GO AGAIN!</button>\n        </div>\n\n        <!-- Mobile Controls -->\n        <div id=\"mobileControls\">\n            <div id=\"dpad\">\n                <div class=\"control-btn\" id=\"btnUp\">\u2191</div>\n                <div class=\"control-btn\" id=\"btnLeft\">\u2190</div>\n                <div class=\"control-btn\" id=\"btnRight\">\u2192</div>\n                <div class=\"control-btn\" id=\"btnDown\">\u2193</div>\n            </div>\n            <div id=\"actionBtns\">\n                <div class=\"action-btn\" id=\"btnA\">A</div>\n                <div class=\"action-btn\" id=\"btnB\">B</div>\n                <div class=\"action-btn\" id=\"btnC\">C</div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        const canvas = document.getElementById('gameCanvas');\n        const ctx = canvas.getContext('2d');\n        \n        // Game constants\n        const COLS = 10;\n        const ROWS = 20;\n        const BLOCK_SIZE = 30;\n        canvas.width = COLS * BLOCK_SIZE;\n        canvas.height = ROWS * BLOCK_SIZE;\n\n        // Game state\n        let board = [];\n        let currentPiece = null;\n        let currentX = 0;\n        let currentY = 0;\n        let score = 0;\n        let lines = 0;\n        let goblinCount = 0;\n        let gameRunning = true;\n        let dropCounter = 0;\n        let dropInterval = 1000;\n        let lastTime = 0;\n\n        // Goblin-themed tetromino shapes (with goblin parts!)\n        const PIECES = [\n            { shape: [[1,1,1,1]], color: '#2ecc71', name: 'Goblin Spear' }, // I\n            { shape: [[1,1],[1,1]], color: '#e74c3c', name: 'Goblin Head' }, // O\n            { shape: [[0,1,0],[1,1,1]], color: '#f39c12', name: 'Goblin Hat' }, // T\n            { shape: [[1,0,0],[1,1,1]], color: '#3498db', name: 'Goblin Claw' }, // L\n            { shape: [[0,0,1],[1,1,1]], color: '#9b59b6', name: 'Goblin Tooth' }, // J\n            { shape: [[1,1,0],[0,1,1]], color: '#1abc9c', name: 'Goblin Ear' }, // S\n            { shape: [[0,1,1],[1,1,0]], color: '#e67e22', name: 'Goblin Nose' }  // Z\n        ];\n\n        // Initialize board\n        function initBoard() {\n            board = Array(ROWS).fill(null).map(() => Array(COLS).fill(0));\n        }\n\n        // Create new piece\n        function createPiece() {\n            const piece = PIECES[Math.floor(Math.random() * PIECES.length)];\n            currentPiece = JSON.parse(JSON.stringify(piece));\n            currentX = Math.floor(COLS / 2) - Math.floor(currentPiece.shape[0].length / 2);\n            currentY = 0;\n\n            if (collision(currentX, currentY, currentPiece.shape)) {\n                gameOver();\n            }\n        }\n\n        // Check collision\n        function collision(x, y, shape) {\n            for (let row = 0; row < shape.length; row++) {\n                for (let col = 0; col < shape[row].length; col++) {\n                    if (shape[row][col]) {\n                        const newX = x + col;\n                        const newY = y + row;\n                        \n                        if (newX < 0 || newX >= COLS || newY >= ROWS) {\n                            return true;\n                        }\n                        \n                        if (newY >= 0 && board[newY][newX]) {\n                            return true;\n                        }\n                    }\n                }\n            }\n            return false;\n        }\n\n        // Merge piece to board\n        function merge() {\n            for (let row = 0; row < currentPiece.shape.length; row++) {\n                for (let col = 0; col < currentPiece.shape[row].length; col++) {\n                    if (currentPiece.shape[row][col]) {\n                        const y = currentY + row;\n                        const x = currentX + col;\n                        if (y >= 0) {\n                            board[y][x] = currentPiece.color;\n                        }\n                    }\n                }\n            }\n        }\n\n        // Rotate piece\n        function rotate(shape) {\n            const newShape = [];\n            for (let col = 0; col < shape[0].length; col++) {\n                const newRow = [];\n                for (let row = shape.length - 1; row >= 0; row--) {\n                    newRow.push(shape[row][col]);\n                }\n                newShape.push(newRow);\n            }\n            return newShape;\n        }\n\n        // Clear lines and spawn goblins\n        function clearLines() {\n            let linesCleared = 0;\n            \n            for (let row = ROWS - 1; row >= 0; row--) {\n                if (board[row].every(cell => cell !== 0)) {\n                    board.splice(row, 1);\n                    board.unshift(Array(COLS).fill(0));\n                    linesCleared++;\n                    row++; // Check same row again\n                    \n                    // Spawn a goblin (random mischief)\n                    spawnGoblin();\n                }\n            }\n            \n            if (linesCleared > 0) {\n                lines += linesCleared;\n                score += linesCleared * 100 * linesCleared; // Bonus for combos\n                document.getElementById('lines').textContent = lines;\n                document.getElementById('score').textContent = score;\n            }\n        }\n\n        // Goblin mischief - randomly adds blocks\n        function spawnGoblin() {\n            goblinCount++;\n            document.getElementById('goblins').textContent = goblinCount;\n            \n            // Goblin adds 1-3 random blocks to the board\n            const blocksToAdd = Math.floor(Math.random() * 3) + 1;\n            for (let i = 0; i < blocksToAdd; i++) {\n                const col = Math.floor(Math.random() * COLS);\n                const row = ROWS - 1;\n                \n                // Find lowest empty spot in column\n                for (let r = ROWS - 1; r >= 0; r--) {\n                    if (board[r][col] === 0) {\n                        board[r][col] = '#4a4a4a'; // Goblin stone color\n                        break;\n                    }\n                }\n            }\n        }\n\n        // Move piece down\n        function moveDown() {\n            if (!collision(currentX, currentY + 1, currentPiece.shape)) {\n                currentY++;\n            } else {\n                merge();\n                clearLines();\n                createPiece();\n                score += 10;\n                document.getElementById('score').textContent = score;\n            }\n        }\n\n        // Hard drop\n        function hardDrop() {\n            while (!collision(currentX, currentY + 1, currentPiece.shape)) {\n                currentY++;\n                score += 2;\n            }\n            merge();\n            clearLines();\n            createPiece();\n            document.getElementById('score').textContent = score;\n        }\n\n        // Draw game\n        function draw() {\n            // Clear canvas\n            ctx.fillStyle = '#1a1a1a';\n            ctx.fillRect(0, 0, canvas.width, canvas.height);\n\n            // Draw grid\n            ctx.strokeStyle = '#333';\n            ctx.lineWidth = 1;\n            for (let row = 0; row <= ROWS; row++) {\n                ctx.beginPath();\n                ctx.moveTo(0, row * BLOCK_SIZE);\n                ctx.lineTo(COLS * BLOCK_SIZE, row * BLOCK_SIZE);\n                ctx.stroke();\n            }\n            for (let col = 0; col <= COLS; col++) {\n                ctx.beginPath();\n                ctx.moveTo(col * BLOCK_SIZE, 0);\n                ctx.lineTo(col * BLOCK_SIZE, ROWS * BLOCK_SIZE);\n                ctx.stroke();\n            }\n\n            // Draw board\n            for (let row = 0; row < ROWS; row++) {\n                for (let col = 0; col < COLS; col++) {\n                    if (board[row][col]) {\n                        ctx.fillStyle = board[row][col];\n                        ctx.fillRect(col * BLOCK_SIZE, row * BLOCK_SIZE, BLOCK_SIZE - 1, BLOCK_SIZE - 1);\n                        \n                        // Add goblin face on goblin blocks\n                        if (board[row][col] === '#4a4a4a') {\n                            ctx.fillStyle = '#ff0000';\n                            ctx.fillRect(col * BLOCK_SIZE + 8, row * BLOCK_SIZE + 8, 4, 4);\n                            ctx.fillRect(col * BLOCK_SIZE + 18, row * BLOCK_SIZE + 8, 4, 4);\n                            ctx.fillStyle = '#00ff00';\n                            ctx.fillRect(col * BLOCK_SIZE + 10, row * BLOCK_SIZE + 18, 10, 3);\n                        }\n                    }\n                }\n            }\n\n            // Draw current piece\n            if (currentPiece) {\n                ctx.fillStyle = currentPiece.color;\n                for (let row = 0; row < currentPiece.shape.length; row++) {\n                    for (let col = 0; col < currentPiece.shape[row].length; col++) {\n                        if (currentPiece.shape[row][col]) {\n                            ctx.fillRect(\n                                (currentX + col) * BLOCK_SIZE,\n                                (currentY + row) * BLOCK_SIZE,\n                                BLOCK_SIZE - 1,\n                                BLOCK_SIZE - 1\n                            );\n                        }\n                    }\n                }\n            }\n        }\n\n        // Game loop\n        function update(time = 0) {\n            if (!gameRunning) return;\n\n            const deltaTime = time - lastTime;\n            lastTime = time;\n            dropCounter += deltaTime;\n\n            if (dropCounter > dropInterval) {\n                moveDown();\n                dropCounter = 0;\n            }\n\n            draw();\n            requestAnimationFrame(update);\n        }\n\n        // Game over\n        function gameOver() {\n            gameRunning = false;\n            document.getElementById('finalScore').textContent = score;\n            document.getElementById('gameOver').style.display = 'block';\n        }\n\n        // Restart game\n        function restart() {\n            initBoard();\n            score = 0;\n            lines = 0;\n            goblinCount = 0;\n            gameRunning = true;\n            dropCounter = 0;\n            document.getElementById('score').textContent = score;\n            document.getElementById('lines').textContent = lines;\n            document.getElementById('goblins').textContent = goblinCount;\n            document.getElementById('gameOver').style.display = 'none';\n            createPiece();\n            update();\n        }\n\n        // Keyboard controls\n        document.addEventListener('keydown', (e) => {\n            if (!gameRunning) return;\n\n            switch(e.key) {\n                case 'ArrowLeft':\n                case 'a':\n                case 'A':\n                    if (!collision(currentX - 1, currentY, currentPiece.shape)) {\n                        currentX--;\n                    }\n                    break;\n                case 'ArrowRight':\n                case 'd':\n                case 'D':\n                    if (!collision(currentX + 1, currentY, currentPiece.shape)) {\n                        currentX++;\n                    }\n                    break;\n                case 'ArrowDown':\n                case 's':\n                case 'S':\n                    moveDown();\n                    break;\n                case 'ArrowUp':\n                case 'w':\n                case 'W':\n                case 'b':\n                case 'B':\n                    const rotated = rotate(currentPiece.shape);\n                    if (!collision(currentX, currentY, rotated)) {\n                        currentPiece.shape = rotated;\n                    }\n                    break;\n                case ' ':\n                case 'c':\n                case 'C':\n                    hardDrop();\n                    break;\n            }\n            draw();\n        });\n\n        // Mobile controls\n        function setupMobileControls() {\n            const buttons = {\n                btnLeft: () => {\n                    if (!collision(currentX - 1, currentY, currentPiece.shape)) {\n                        currentX--;\n                        draw();\n                    }\n                },\n                btnRight: () => {\n                    if (!collision(currentX + 1, currentY, currentPiece.shape)) {\n                        currentX++;\n                        draw();\n                    }\n                },\n                btnDown: () => {\n                    moveDown();\n                    draw();\n                },\n                btnUp: () => {\n                    const rotated = rotate(currentPiece.shape);\n                    if (!collision(currentX, currentY, rotated)) {\n                        currentPiece.shape = rotated;\n                        draw();\n                    }\n                },\n                btnA: () => {\n                    if (!collision(currentX - 1, currentY, currentPiece.shape)) {\n                        currentX--;\n                        draw();\n                    }\n                },\n                btnB: () => {\n                    const rotated = rotate(currentPiece.shape);\n                    if (!collision(currentX, currentY, rotated)) {\n                        currentPiece.shape = rotated;\n                        draw();\n                    }\n                },\n                btnC: () => {\n                    hardDrop();\n                    draw();\n                }\n            };\n\n            for (const [id, action] of Object.entries(buttons)) {\n                const btn = document.getElementById(id);\n                btn.addEventListener('touchstart', (e) => {\n                    e.preventDefault();\n                    if (gameRunning) action();\n                });\n            }\n        }\n\n        // Restart button\n        document.getElementById('restartBtn').addEventListener('click', restart);\n\n        // Initialize and start game\n        initBoard();\n        createPiece();\n        setupMobileControls();\n        update();\n    </script>\n</body>\n</html>"
}